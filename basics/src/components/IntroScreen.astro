---
// Full-screen envelope — the entire viewport is the envelope
// Golden wax seal "TM" centered → tap → seal cracks & shatters → 
// envelope splits open (two halves slide apart) → invitation card fades in → transition to quiz
---

<div id="intro-screen" class="fixed inset-0 z-[200] flex items-center justify-center overflow-hidden cursor-pointer select-none" role="button" aria-label="Abrir convite" tabindex="0">
	
	<!-- Solid background that stays behind the envelope halves so the main page never shows -->
	<div id="intro-bg" class="absolute inset-0 bg-[#f5f0e3]"></div>

	<!-- ENVELOPE TOP HALF (slides up on open) -->
	<div id="envelope-top" class="envelope-half envelope-top">
		<div class="envelope-base"></div>
		<div class="envelope-texture"></div>
		<div class="envelope-gold-frame-top"></div>
	</div>

	<!-- ENVELOPE BOTTOM HALF (slides down on open) -->
	<div id="envelope-bottom" class="envelope-half envelope-bottom">
		<div class="envelope-base"></div>
		<div class="envelope-texture"></div>
		<div class="envelope-gold-frame-bottom"></div>
	</div>

	<!-- Center fold line -->
	<div id="fold-line" class="fold-line"></div>

	<!-- Subtle floating gold particles -->
	<div class="particles" aria-hidden="true">
		<span class="particle p1"></span>
		<span class="particle p2"></span>
		<span class="particle p3"></span>
		<span class="particle p4"></span>
		<span class="particle p5"></span>
		<span class="particle p6"></span>
	</div>

	<!-- Golden wax seal with TM monogram -->
	<div id="wax-seal" class="wax-seal">
		<div class="seal-outer-ring"></div>
		<div class="seal-body">
			<div class="seal-shine"></div>
			<span class="seal-monogram">TM</span>
		</div>
		<!-- Seal fragments (appear on break) -->
		<div id="seal-fragments" class="seal-fragments">
			<span class="fragment f1"></span>
			<span class="fragment f2"></span>
			<span class="fragment f3"></span>
			<span class="fragment f4"></span>
			<span class="fragment f5"></span>
			<span class="fragment f6"></span>
		</div>
	</div>

	<!-- The invitation card (hidden behind envelope, fades in after split) -->
	<div id="invitation-card" class="invitation-card">
		<div class="card-paper"></div>
		<div class="card-content">
			<div class="card-top-ornament"></div>
			<p class="card-label">Convite de Casamento</p>
			<h2 class="card-names">Tânia <span class="card-amp">&</span> Miguel</h2>
			<div class="card-divider">
				<span class="card-line"></span>
				<span class="card-leaf">🌿</span>
				<span class="card-line"></span>
			</div>
			<p class="card-date">20 de Junho de 2027</p>
			<p class="card-venue">Quinta da Lage — Santo Tirso</p>
			<div class="card-bottom-ornament"></div>
		</div>
	</div>

	<!-- Tap hint -->
	<p id="tap-hint" class="tap-hint">Toque para abrir</p>
</div>

<style>
	/* ============================================
	   ENVELOPE HALVES — full screen split
	   ============================================ */
	.envelope-half {
		position: absolute;
		left: 0;
		right: 0;
		overflow: hidden;
		z-index: 3;
		transition: transform 1s cubic-bezier(0.6, 0, 0.2, 1);
	}

	.envelope-top {
		top: 0;
		bottom: 50%;
		transform: translateY(0);
	}

	.envelope-bottom {
		top: 50%;
		bottom: 0;
		transform: translateY(0);
	}

	.envelope-top.open {
		transform: translateY(-100%);
	}

	.envelope-bottom.open {
		transform: translateY(100%);
	}

	.envelope-base {
		position: absolute;
		inset: 0;
		background: linear-gradient(160deg, #7a8c5e 0%, #6b7d50 30%, #5f7244 60%, #5c6e44 100%);
	}

	.envelope-texture {
		position: absolute;
		inset: 0;
		opacity: 0.1;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='1.1' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
	}

	.envelope-gold-frame-top {
		position: absolute;
		top: 12px;
		left: 12px;
		right: 12px;
		bottom: 0;
		border-top: 1.5px solid rgba(212, 168, 83, 0.3);
		border-left: 1.5px solid rgba(212, 168, 83, 0.3);
		border-right: 1.5px solid rgba(212, 168, 83, 0.3);
		pointer-events: none;
	}

	.envelope-gold-frame-bottom {
		position: absolute;
		top: 0;
		left: 12px;
		right: 12px;
		bottom: 12px;
		border-bottom: 1.5px solid rgba(212, 168, 83, 0.3);
		border-left: 1.5px solid rgba(212, 168, 83, 0.3);
		border-right: 1.5px solid rgba(212, 168, 83, 0.3);
		pointer-events: none;
	}

	/* Center fold line */
	.fold-line {
		position: absolute;
		top: 50%;
		left: 5%;
		right: 5%;
		height: 1px;
		background: rgba(0,0,0,0.12);
		transform: translateY(-50%);
		z-index: 4;
		transition: opacity 0.3s ease;
	}

	.fold-line.hidden {
		opacity: 0;
	}

	/* ============================================
	   PARTICLES
	   ============================================ */
	.particles {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 5;
	}

	.particle {
		position: absolute;
		width: 2px;
		height: 2px;
		border-radius: 50%;
		background: rgba(212, 168, 83, 0.5);
		box-shadow: 0 0 6px rgba(212, 168, 83, 0.3);
	}

	.p1 { left: 15%; animation: drift 14s linear infinite; animation-delay: 0s; }
	.p2 { left: 35%; animation: drift 16s linear infinite; animation-delay: 2s; }
	.p3 { left: 55%; animation: drift 12s linear infinite; animation-delay: 4s; }
	.p4 { left: 70%; animation: drift 15s linear infinite; animation-delay: 1s; }
	.p5 { left: 85%; animation: drift 13s linear infinite; animation-delay: 3s; }
	.p6 { left: 45%; animation: drift 17s linear infinite; animation-delay: 5s; }

	@keyframes drift {
		0% { bottom: -5%; opacity: 0; transform: translateX(0) scale(0.5); }
		10% { opacity: 0.5; }
		50% { transform: translateX(10px) scale(1); }
		90% { opacity: 0.3; }
		100% { bottom: 105%; opacity: 0; transform: translateX(-8px) scale(0.3); }
	}

	/* ============================================
	   WAX SEAL — large, golden, centered
	   ============================================ */
	.wax-seal {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		z-index: 30;
		transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease;
	}

	.seal-outer-ring {
		position: absolute;
		inset: -6px;
		border-radius: 50%;
		border: 2px solid rgba(212, 168, 83, 0.2);
		animation: sealPulse 3s ease-in-out infinite;
	}

	@keyframes sealPulse {
		0%, 100% { transform: scale(1); opacity: 0.5; }
		50% { transform: scale(1.08); opacity: 1; }
	}

	.seal-body {
		width: 80px;
		height: 80px;
		border-radius: 50%;
		background: radial-gradient(circle at 35% 30%, #edc972 0%, #d4983a 35%, #b87a2e 70%, #995c27 100%);
		box-shadow: 0 6px 30px rgba(100,60,0,0.5), 
		            0 2px 8px rgba(0,0,0,0.3),
		            inset 0 2px 6px rgba(255,240,180,0.35),
		            inset 0 -3px 6px rgba(0,0,0,0.2);
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		overflow: hidden;
	}

	@media (min-width: 640px) {
		.seal-body {
			width: 100px;
			height: 100px;
		}
		.seal-outer-ring {
			inset: -8px;
		}
		.seal-monogram {
			font-size: 1.6rem !important;
		}
	}

	.seal-shine {
		position: absolute;
		top: 10%;
		left: 15%;
		width: 45%;
		height: 30%;
		border-radius: 50%;
		background: rgba(255,255,255,0.22);
		filter: blur(4px);
	}

	.seal-monogram {
		font-family: 'Playfair Display', serif;
		font-weight: 600;
		font-size: 1.3rem;
		color: rgba(255, 250, 230, 0.95);
		text-shadow: 0 1px 3px rgba(0,0,0,0.3);
		position: relative;
		z-index: 2;
		letter-spacing: 0.1em;
	}

	/* Seal fragments (fly out on break) */
	.seal-fragments {
		position: absolute;
		inset: 0;
		pointer-events: none;
		opacity: 0;
	}

	.seal-fragments.active .fragment {
		opacity: 1;
	}

	.fragment {
		position: absolute;
		width: 12px;
		height: 12px;
		border-radius: 50% 30% 50% 30%;
		background: radial-gradient(circle, #d4983a, #b87a2e);
		box-shadow: 0 2px 6px rgba(0,0,0,0.3);
		opacity: 0;
		transition: transform 0.7s cubic-bezier(0.2, 0.8, 0.3, 1), opacity 0.7s ease;
	}

	.seal-fragments.active .f1 { transform: translate(-40px, -50px) rotate(120deg) scale(0.5); opacity: 0; }
	.seal-fragments.active .f2 { transform: translate(45px, -40px) rotate(-80deg) scale(0.4); opacity: 0; }
	.seal-fragments.active .f3 { transform: translate(-50px, 30px) rotate(200deg) scale(0.6); opacity: 0; }
	.seal-fragments.active .f4 { transform: translate(40px, 45px) rotate(-150deg) scale(0.5); opacity: 0; }
	.seal-fragments.active .f5 { transform: translate(10px, -60px) rotate(90deg) scale(0.3); opacity: 0; }
	.seal-fragments.active .f6 { transform: translate(-20px, 55px) rotate(-60deg) scale(0.4); opacity: 0; }

	.f1 { top: 20%; left: 30%; }
	.f2 { top: 25%; right: 25%; }
	.f3 { bottom: 30%; left: 20%; }
	.f4 { bottom: 25%; right: 20%; }
	.f5 { top: 10%; left: 50%; }
	.f6 { bottom: 15%; left: 45%; }

	/* Seal shake before break */
	.wax-seal.shake {
		animation: sealShake 0.4s ease;
	}

	@keyframes sealShake {
		0%, 100% { transform: translate(-50%, -50%) rotate(0deg); }
		20% { transform: translate(-50%, -50%) rotate(-3deg) scale(1.02); }
		40% { transform: translate(-50%, -50%) rotate(3deg) scale(1.04); }
		60% { transform: translate(-50%, -50%) rotate(-2deg) scale(1.02); }
		80% { transform: translate(-50%, -50%) rotate(2deg) scale(1.01); }
	}

	.wax-seal.broken {
		transform: translate(-50%, -50%) scale(1.2);
		opacity: 0;
	}

	/* ============================================
	   INVITATION CARD
	   ============================================ */
	.invitation-card {
		position: absolute;
		left: 50%;
		top: 50%;
		transform: translate(-50%, -50%) scale(0.85);
		width: 78vw;
		max-width: 360px;
		aspect-ratio: 3 / 4;
		z-index: 2;
		border-radius: 8px;
		overflow: hidden;
		opacity: 0;
		transition: opacity 0.8s ease 0.2s, transform 0.8s cubic-bezier(0.34, 1.2, 0.64, 1) 0.2s;
	}

	.card-paper {
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, #fffef9 0%, #faf7f0 100%);
		box-shadow: 0 12px 50px rgba(0,0,0,0.25), 0 4px 16px rgba(0,0,0,0.1);
		border: 1px solid rgba(212,168,83,0.15);
	}

	.card-content {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 2rem 1.5rem;
		opacity: 0;
		transform: translateY(10px);
		transition: opacity 0.6s ease 0.3s, transform 0.6s ease 0.3s;
	}

	.card-top-ornament,
	.card-bottom-ornament {
		width: 40px;
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(143,138,94,0.5), transparent);
	}

	.card-top-ornament { margin-bottom: 16px; }
	.card-bottom-ornament { margin-top: 16px; }

	.card-label {
		font-size: 0.6rem;
		text-transform: uppercase;
		letter-spacing: 0.3em;
		color: #8f8a5e;
		margin-bottom: 14px;
	}

	.card-names {
		font-family: 'Playfair Display', serif;
		font-size: clamp(1.8rem, 6vw, 2.8rem);
		font-weight: 300;
		color: #2a2a2a;
		letter-spacing: -0.02em;
	}

	.card-amp {
		color: #8f8a5e;
		font-style: italic;
		margin: 0 4px;
	}

	.card-divider {
		display: flex;
		align-items: center;
		gap: 10px;
		margin: 14px 0;
	}

	.card-line {
		width: 28px;
		height: 1px;
		background: #d4c5a5;
	}

	.card-leaf {
		font-size: 0.9rem;
	}

	.card-date {
		font-size: 0.85rem;
		color: #555;
		letter-spacing: 0.05em;
		margin-top: 4px;
	}

	.card-venue {
		font-size: 0.7rem;
		color: #999;
		margin-top: 5px;
	}

	/* Card visible */
	.invitation-card.visible {
		opacity: 1;
		transform: translate(-50%, -50%) scale(1);
	}

	.invitation-card.visible .card-content {
		opacity: 1;
		transform: translateY(0);
	}

	/* ============================================
	   DISMISS
	   ============================================ */
	#intro-screen.dismissed {
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.7s ease;
	}

	#intro-bg {
		z-index: 1;
		transition: none;
	}

	/* ============================================
	   TAP HINT
	   ============================================ */
	.tap-hint {
		position: absolute;
		bottom: 2rem;
		left: 50%;
		transform: translateX(-50%);
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.3em;
		color: rgba(255,255,255,0.4);
		z-index: 40;
		animation: hintPulse 2.5s ease-in-out infinite;
		transition: opacity 0.4s ease;
	}

	@keyframes hintPulse {
		0%, 100% { opacity: 0.35; transform: translateX(-50%) translateY(0); }
		50% { opacity: 0.65; transform: translateX(-50%) translateY(-3px); }
	}
</style>

<script>
	const intro = document.getElementById('intro-screen');
	const seal = document.getElementById('wax-seal');
	const sealFragments = document.getElementById('seal-fragments');
	const envelopeTop = document.getElementById('envelope-top');
	const envelopeBottom = document.getElementById('envelope-bottom');
	const foldLine = document.getElementById('fold-line');
	const card = document.getElementById('invitation-card');
	const hint = document.getElementById('tap-hint');

	let opened = false;

	function openEnvelope() {
		if (opened) return;
		opened = true;

		if (hint) hint.style.opacity = '0';

		// Step 1: Seal shakes (0ms)
		seal?.classList.add('shake');

		// Step 2: Seal breaks & fragments fly (500ms)
		setTimeout(() => {
			seal?.classList.remove('shake');
			seal?.classList.add('broken');
			sealFragments?.classList.add('active');
			foldLine?.classList.add('hidden');
		}, 500);

		// Step 3: Envelope halves split apart (900ms)
		setTimeout(() => {
			envelopeTop?.classList.add('open');
			envelopeBottom?.classList.add('open');
		}, 900);

		// Step 4: Card appears (1400ms)
		setTimeout(() => {
			card?.classList.add('visible');
		}, 1400);

		// Step 5: Dismiss intro, show quiz (3800ms)
		setTimeout(() => {
			intro?.classList.add('dismissed');
			if (typeof (window as any).showQuizGate === 'function') {
				(window as any).showQuizGate();
			}
		}, 4000);

		// Step 6: Remove from DOM
		setTimeout(() => {
			intro?.remove();
		}, 4700);
	}

	// Lock scroll
	document.body.style.overflow = 'hidden';
	document.documentElement.style.overflow = 'hidden';
	
	(window as any).__preventScroll = function(e: Event) {
		e.preventDefault();
	};
	document.addEventListener('wheel', (window as any).__preventScroll, { passive: false });
	document.addEventListener('touchmove', (window as any).__preventScroll, { passive: false });

	intro?.addEventListener('click', (e) => {
		e.stopPropagation();
		e.stopImmediatePropagation();
		openEnvelope();
	});

	intro?.addEventListener('mouseup', (e) => { e.stopPropagation(); });
	intro?.addEventListener('touchend', (e) => { e.stopPropagation(); });

	intro?.addEventListener('keydown', (e) => {
		if (e.key === 'Enter' || e.key === ' ') {
			e.preventDefault();
			openEnvelope();
		}
	});
</script>
