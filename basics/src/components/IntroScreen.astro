---
// Cinematic envelope intro — rich visuals, reliable animation
// Envelope with wax seal → seal breaks → flap lifts (2D) → card rises → zoom into card → fade to site
---

<div id="intro-screen" class="fixed inset-0 z-[200] flex items-center justify-center overflow-hidden cursor-pointer select-none" role="button" aria-label="Abrir convite" tabindex="0">
	
	<!-- Cinematic background with depth -->
	<div class="intro-bg">
		<div class="bg-gradient"></div>
		<div class="bg-vignette"></div>
		<div class="bg-grain"></div>
	</div>

	<!-- Ambient light that intensifies on open -->
	<div id="ambient-light" class="ambient-light"></div>

	<!-- Floating golden particles -->
	<div class="particles" aria-hidden="true">
		<span class="particle p1"></span>
		<span class="particle p2"></span>
		<span class="particle p3"></span>
		<span class="particle p4"></span>
		<span class="particle p5"></span>
		<span class="particle p6"></span>
		<span class="particle p7"></span>
		<span class="particle p8"></span>
		<span class="particle p9"></span>
		<span class="particle p10"></span>
	</div>

	<!-- Twinkling stars -->
	<div class="stars" aria-hidden="true">
		<span class="star s1"></span>
		<span class="star s2"></span>
		<span class="star s3"></span>
		<span class="star s4"></span>
		<span class="star s5"></span>
		<span class="star s6"></span>
		<span class="star s7"></span>
		<span class="star s8"></span>
		<span class="star s9"></span>
		<span class="star s10"></span>
		<span class="star s11"></span>
		<span class="star s12"></span>
		<span class="star s13"></span>
		<span class="star s14"></span>
		<span class="star s15"></span>
	</div>

	<!-- Bokeh lights (soft blurred circles) -->
	<div class="bokeh-lights" aria-hidden="true">
		<span class="bokeh b1"></span>
		<span class="bokeh b2"></span>
		<span class="bokeh b3"></span>
		<span class="bokeh b4"></span>
		<span class="bokeh b5"></span>
		<span class="bokeh b6"></span>
		<span class="bokeh b7"></span>
		<span class="bokeh b8"></span>
	</div>

	<!-- Floating golden rings -->
	<div class="rings" aria-hidden="true">
		<span class="ring r1"></span>
		<span class="ring r2"></span>
		<span class="ring r3"></span>
	</div>

	<!-- Main envelope assembly -->
	<div id="envelope-assembly" class="envelope-assembly">
		
		<!-- Shadow beneath envelope -->
		<div id="envelope-shadow" class="envelope-shadow"></div>

		<!-- Envelope body -->
		<div class="envelope-body">
			<!-- Textured sage green paper -->
			<div class="envelope-surface"></div>
			<!-- Embossed border -->
			<div class="envelope-border"></div>
			<!-- Gold foil edge accent -->
			<div class="envelope-gold-edge"></div>
		</div>

		<!-- The invitation card (starts inside, rises up) -->
		<div id="invitation-card" class="invitation-card">
			<div class="card-paper"></div>
			<div class="card-content">
				<div class="card-top-ornament"></div>
				<p class="card-label">Convite de Casamento</p>
				<h2 class="card-names">Tânia <span class="card-amp">&</span> Miguel</h2>
				<div class="card-heart-divider">
					<span class="card-line"></span>
					<svg class="card-heart" width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
					<span class="card-line"></span>
				</div>
				<p class="card-date">20 de Junho de 2027</p>
				<p class="card-venue">Quinta da Lage — Santo Tirso</p>
				<div class="card-bottom-ornament"></div>
			</div>
		</div>

		<!-- Envelope flap (top triangle, lifts up via 2D) -->
		<div id="envelope-flap" class="envelope-flap">
			<div class="flap-surface"></div>
			<div class="flap-fold-shadow"></div>
		</div>

		<!-- Wax seal (centered on flap edge) -->
		<div id="wax-seal" class="wax-seal">
			<div class="seal-body">
				<div class="seal-shine"></div>
				<span class="seal-monogram">T&M</span>
			</div>
			<!-- Seal crack lines (appear on break) -->
			<div id="seal-cracks" class="seal-cracks">
				<span class="crack c1"></span>
				<span class="crack c2"></span>
				<span class="crack c3"></span>
				<span class="crack c4"></span>
			</div>
		</div>
	</div>

	<!-- Tap hint -->
	<p id="tap-hint" class="tap-hint">Toque para abrir</p>
</div>

<style>
	/* ============================================
	   BACKGROUND & ATMOSPHERE
	   ============================================ */
	.intro-bg {
		position: absolute;
		inset: 0;
	}

	.bg-gradient {
		position: absolute;
		inset: 0;
		background: linear-gradient(170deg, #1c2418 0%, #2a3025 30%, #1f261c 70%, #151a13 100%);
	}

	.bg-vignette {
		position: absolute;
		inset: 0;
		background: radial-gradient(ellipse at 50% 45%, transparent 30%, rgba(0,0,0,0.6) 100%);
	}

	.bg-grain {
		position: absolute;
		inset: 0;
		opacity: 0.04;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
	}

	/* Ambient warm light */
	.ambient-light {
		position: absolute;
		top: 10%;
		left: 50%;
		width: 600px;
		height: 600px;
		transform: translateX(-50%);
		border-radius: 50%;
		background: radial-gradient(circle, rgba(255,240,200,0.12) 0%, transparent 70%);
		pointer-events: none;
		transition: opacity 1.5s ease, transform 1.5s ease;
	}

	.ambient-light.bright {
		opacity: 1;
		background: radial-gradient(circle, rgba(255,240,200,0.25) 0%, transparent 70%);
		transform: translateX(-50%) scale(1.4);
	}

	/* ============================================
	   PARTICLES
	   ============================================ */
	.particles {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 5;
	}

	.particle {
		position: absolute;
		width: 2px;
		height: 2px;
		border-radius: 50%;
		background: rgba(212, 168, 83, 0.5);
		box-shadow: 0 0 4px rgba(212, 168, 83, 0.3);
	}

	.p1  { left: 12%; animation: drift 10s linear infinite; animation-delay: 0s; }
	.p2  { left: 28%; animation: drift 13s linear infinite; animation-delay: 1.2s; }
	.p3  { left: 42%; animation: drift 9s linear infinite; animation-delay: 2.8s; }
	.p4  { left: 58%; animation: drift 12s linear infinite; animation-delay: 0.6s; }
	.p5  { left: 72%; animation: drift 11s linear infinite; animation-delay: 3.5s; }
	.p6  { left: 85%; animation: drift 14s linear infinite; animation-delay: 1.8s; }
	.p7  { left: 20%; animation: drift 8s linear infinite; animation-delay: 4.2s; }
	.p8  { left: 50%; animation: drift 15s linear infinite; animation-delay: 2.1s; }
	.p9  { left: 65%; animation: drift 10s linear infinite; animation-delay: 5s; }
	.p10 { left: 35%; animation: drift 12s linear infinite; animation-delay: 3s; }

	@keyframes drift {
		0% { bottom: -5%; opacity: 0; transform: translateX(0) scale(0.5); }
		10% { opacity: 0.7; }
		50% { transform: translateX(15px) scale(1); }
		90% { opacity: 0.5; }
		100% { bottom: 105%; opacity: 0; transform: translateX(-10px) scale(0.3); }
	}

	/* ============================================
	   TWINKLING STARS
	   ============================================ */
	.stars {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 3;
	}

	.star {
		position: absolute;
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.6);
		box-shadow: 0 0 6px rgba(255, 255, 255, 0.4), 0 0 12px rgba(255, 250, 200, 0.2);
		animation: twinkle ease-in-out infinite;
	}

	.s1  { top: 8%; left: 15%; animation-duration: 3s; animation-delay: 0s; }
	.s2  { top: 12%; left: 78%; animation-duration: 4s; animation-delay: 0.5s; }
	.s3  { top: 22%; left: 45%; animation-duration: 3.5s; animation-delay: 1s; width: 2px; height: 2px; }
	.s4  { top: 5%; left: 60%; animation-duration: 4.5s; animation-delay: 1.5s; }
	.s5  { top: 30%; left: 88%; animation-duration: 3s; animation-delay: 2s; width: 2px; height: 2px; }
	.s6  { top: 18%; left: 32%; animation-duration: 5s; animation-delay: 0.8s; }
	.s7  { top: 35%; left: 8%; animation-duration: 3.8s; animation-delay: 2.5s; width: 2px; height: 2px; }
	.s8  { top: 15%; left: 92%; animation-duration: 4.2s; animation-delay: 1.2s; }
	.s9  { top: 70%; left: 5%; animation-duration: 3.2s; animation-delay: 3s; }
	.s10 { top: 75%; left: 92%; animation-duration: 4s; animation-delay: 0.3s; width: 2px; height: 2px; }
	.s11 { top: 82%; left: 20%; animation-duration: 3.6s; animation-delay: 1.8s; }
	.s12 { top: 88%; left: 70%; animation-duration: 4.8s; animation-delay: 2.2s; width: 2px; height: 2px; }
	.s13 { top: 60%; left: 95%; animation-duration: 3.4s; animation-delay: 0.7s; }
	.s14 { top: 45%; left: 3%; animation-duration: 5.2s; animation-delay: 3.5s; }
	.s15 { top: 55%; left: 97%; animation-duration: 3.9s; animation-delay: 1.4s; width: 2px; height: 2px; }

	@keyframes twinkle {
		0%, 100% { opacity: 0.1; transform: scale(0.8); }
		50% { opacity: 1; transform: scale(1.2); }
	}

	/* ============================================
	   BOKEH LIGHTS
	   ============================================ */
	.bokeh-lights {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 2;
	}

	.bokeh {
		position: absolute;
		border-radius: 50%;
		opacity: 0;
		animation: bokehFloat ease-in-out infinite;
	}

	.b1 { width: 80px; height: 80px; top: 10%; left: 5%; background: radial-gradient(circle, rgba(212,168,83,0.08) 0%, transparent 70%); animation-duration: 8s; animation-delay: 0s; }
	.b2 { width: 120px; height: 120px; top: 60%; left: 80%; background: radial-gradient(circle, rgba(232,160,160,0.06) 0%, transparent 70%); animation-duration: 10s; animation-delay: 1s; }
	.b3 { width: 60px; height: 60px; top: 25%; left: 85%; background: radial-gradient(circle, rgba(255,250,220,0.1) 0%, transparent 70%); animation-duration: 7s; animation-delay: 2s; }
	.b4 { width: 100px; height: 100px; top: 70%; left: 10%; background: radial-gradient(circle, rgba(212,168,83,0.07) 0%, transparent 70%); animation-duration: 9s; animation-delay: 3s; }
	.b5 { width: 70px; height: 70px; top: 85%; left: 50%; background: radial-gradient(circle, rgba(255,240,200,0.08) 0%, transparent 70%); animation-duration: 11s; animation-delay: 1.5s; }
	.b6 { width: 90px; height: 90px; top: 5%; left: 65%; background: radial-gradient(circle, rgba(232,160,160,0.05) 0%, transparent 70%); animation-duration: 12s; animation-delay: 4s; }
	.b7 { width: 50px; height: 50px; top: 40%; left: 2%; background: radial-gradient(circle, rgba(212,168,83,0.09) 0%, transparent 70%); animation-duration: 8.5s; animation-delay: 2.5s; }
	.b8 { width: 110px; height: 110px; top: 50%; left: 90%; background: radial-gradient(circle, rgba(255,250,220,0.06) 0%, transparent 70%); animation-duration: 13s; animation-delay: 0.5s; }

	@keyframes bokehFloat {
		0%, 100% { opacity: 0; transform: translateY(0) scale(0.8); }
		20% { opacity: 1; }
		50% { transform: translateY(-20px) scale(1.1); }
		80% { opacity: 1; }
		100% { opacity: 0; transform: translateY(-40px) scale(0.9); }
	}

	/* ============================================
	   FLOATING GOLDEN RINGS
	   ============================================ */
	.rings {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 4;
	}

	.ring {
		position: absolute;
		border-radius: 50%;
		border: 1px solid rgba(212, 168, 83, 0.15);
		animation: ringPulse ease-in-out infinite;
	}

	.r1 { width: 200px; height: 200px; top: 15%; left: -5%; animation-duration: 12s; animation-delay: 0s; border-color: rgba(212, 168, 83, 0.1); }
	.r2 { width: 150px; height: 150px; top: 60%; right: -3%; animation-duration: 10s; animation-delay: 2s; border-color: rgba(232, 160, 160, 0.08); }
	.r3 { width: 250px; height: 250px; bottom: -5%; left: 30%; animation-duration: 14s; animation-delay: 4s; border-color: rgba(255, 250, 220, 0.06); }

	@keyframes ringPulse {
		0%, 100% { opacity: 0; transform: scale(0.6) rotate(0deg); }
		30% { opacity: 1; }
		70% { opacity: 1; }
		100% { opacity: 0; transform: scale(1.3) rotate(90deg); }
	}

	/* ============================================
	   ENVELOPE ASSEMBLY
	   ============================================ */
	.envelope-assembly {
		position: relative;
		z-index: 10;
		width: 82vw;
		max-width: 400px;
		aspect-ratio: 4 / 2.8;
		animation: envelopeEnter 1s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
	}

	@media (min-width: 640px) {
		.envelope-assembly { width: 380px; }
	}

	@keyframes envelopeEnter {
		from { opacity: 0; transform: translateY(30px) scale(0.9); }
		to { opacity: 1; transform: translateY(0) scale(1); }
	}

	/* Shadow */
	.envelope-shadow {
		position: absolute;
		bottom: -12px;
		left: 12%;
		right: 12%;
		height: 24px;
		border-radius: 50%;
		background: rgba(0,0,0,0.35);
		filter: blur(12px);
		transition: all 1s ease;
	}

	/* Body */
	.envelope-body {
		position: absolute;
		inset: 0;
		border-radius: 8px;
		overflow: hidden;
	}

	.envelope-surface {
		position: absolute;
		inset: 0;
		background: linear-gradient(145deg, #8fa07c 0%, #7a9068 50%, #6e8460 100%);
	}

	.envelope-border {
		position: absolute;
		inset: 8px;
		border: 1px solid rgba(255,255,255,0.08);
		border-radius: 4px;
		pointer-events: none;
	}

	.envelope-gold-edge {
		position: absolute;
		inset: 0;
		border-radius: 8px;
		border: 1px solid rgba(212, 168, 83, 0.15);
		pointer-events: none;
	}

	/* ============================================
	   INVITATION CARD
	   ============================================ */
	.invitation-card {
		position: absolute;
		left: 8%;
		right: 8%;
		top: 8%;
		height: 80%;
		z-index: 2;
		border-radius: 6px;
		overflow: hidden;
		transform: translateY(0);
		opacity: 1;
		transition: transform 1.2s cubic-bezier(0.34, 1.4, 0.64, 1), 
		            box-shadow 1.2s ease,
		            opacity 0.4s ease 1.8s;
	}

	.card-paper {
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, #fffef9 0%, #faf8f3 100%);
		box-shadow: 0 2px 8px rgba(0,0,0,0.08);
	}

	.card-content {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 1.5rem 1rem;
		opacity: 0;
		transform: translateY(6px);
		transition: opacity 0.6s ease, transform 0.6s ease;
	}

	.card-top-ornament,
	.card-bottom-ornament {
		width: 30px;
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(212,168,83,0.4), transparent);
	}

	.card-top-ornament { margin-bottom: 10px; }
	.card-bottom-ornament { margin-top: 10px; }

	.card-label {
		font-size: 0.55rem;
		text-transform: uppercase;
		letter-spacing: 0.3em;
		color: #b0a090;
		margin-bottom: 10px;
	}

	.card-names {
		font-family: 'Playfair Display', serif;
		font-size: clamp(1.5rem, 5vw, 2.2rem);
		font-weight: 300;
		color: #2a2a2a;
		letter-spacing: -0.02em;
	}

	.card-amp {
		color: #e8a0a0;
		font-style: italic;
		margin: 0 2px;
	}

	.card-heart-divider {
		display: flex;
		align-items: center;
		gap: 8px;
		margin: 8px 0;
	}

	.card-line {
		width: 20px;
		height: 1px;
		background: #e0d5c8;
	}

	.card-heart {
		color: #e8a0a0;
	}

	.card-date {
		font-size: 0.75rem;
		color: #777;
		letter-spacing: 0.05em;
	}

	.card-venue {
		font-size: 0.6rem;
		color: #aaa;
		margin-top: 3px;
	}

	/* Card risen state */
	.invitation-card.risen {
		transform: translateY(-85%);
		box-shadow: 0 30px 60px rgba(0,0,0,0.3), 0 10px 20px rgba(0,0,0,0.15);
	}

	.invitation-card.risen .card-content {
		opacity: 1;
		transform: translateY(0);
		transition-delay: 0.4s;
	}

	/* ============================================
	   ENVELOPE FLAP
	   ============================================ */
	.envelope-flap {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 62%;
		z-index: 15;
		clip-path: polygon(0% 0%, 50% 90%, 100% 0%);
		transform: scaleY(1);
		transform-origin: top center;
		transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.5s ease 0.4s;
	}

	.flap-surface {
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, #92a480 0%, #849670 100%);
	}

	.flap-fold-shadow {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 4px;
		background: linear-gradient(to bottom, rgba(0,0,0,0.1), transparent);
	}

	/* Flap open: scale to 0 vertically from top */
	.envelope-flap.open {
		transform: scaleY(0);
		opacity: 0;
	}

	/* ============================================
	   WAX SEAL
	   ============================================ */
	.wax-seal {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		z-index: 25;
		transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease;
	}

	.seal-body {
		width: 52px;
		height: 52px;
		border-radius: 50%;
		background: radial-gradient(circle at 35% 30%, #d44 0%, #b22 40%, #8b1a1a 100%);
		box-shadow: 0 4px 14px rgba(0,0,0,0.4), 
		            inset 0 2px 4px rgba(255,200,200,0.2),
		            inset 0 -2px 4px rgba(0,0,0,0.2);
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		overflow: hidden;
	}

	.seal-shine {
		position: absolute;
		top: 15%;
		left: 20%;
		width: 35%;
		height: 25%;
		border-radius: 50%;
		background: rgba(255,255,255,0.12);
		filter: blur(3px);
	}

	.seal-monogram {
		font-family: 'Playfair Display', serif;
		font-style: italic;
		font-size: 0.8rem;
		color: rgba(255, 210, 170, 0.85);
		text-shadow: 0 1px 2px rgba(0,0,0,0.4);
		position: relative;
		z-index: 2;
	}

	/* Seal cracks */
	.seal-cracks {
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.seal-cracks.visible {
		opacity: 1;
	}

	.crack {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 2px;
		height: 0;
		background: rgba(0,0,0,0.6);
		transform-origin: center;
		transition: height 0.3s ease;
	}

	.seal-cracks.visible .crack {
		height: 28px;
	}

	.c1 { transform: translate(-50%, -50%) rotate(0deg); }
	.c2 { transform: translate(-50%, -50%) rotate(72deg); }
	.c3 { transform: translate(-50%, -50%) rotate(144deg); }
	.c4 { transform: translate(-50%, -50%) rotate(216deg); }

	/* Seal break */
	.wax-seal.broken {
		transform: translate(-50%, -50%) scale(1.2);
		opacity: 0;
	}

	/* ============================================
	   ENVELOPE ASSEMBLY STATES
	   ============================================ */
	.envelope-assembly.zoom {
		transition: transform 1s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.8s ease 0.4s;
		transform: scale(0.85);
		opacity: 0;
	}

	/* Shadow lifts when card rises */
	.envelope-shadow.lifted {
		opacity: 0.15;
		transform: scaleX(0.7);
		filter: blur(18px);
	}

	/* ============================================
	   DISMISS
	   ============================================ */
	#intro-screen.dismissed {
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.6s ease;
	}

	/* ============================================
	   TAP HINT
	   ============================================ */
	.tap-hint {
		position: absolute;
		bottom: 1.5rem;
		left: 50%;
		transform: translateX(-50%);
		font-size: 0.6rem;
		text-transform: uppercase;
		letter-spacing: 0.3em;
		color: rgba(255,255,255,0.25);
		z-index: 40;
		animation: hintPulse 2.5s ease-in-out infinite;
		transition: opacity 0.4s ease;
	}

	@keyframes hintPulse {
		0%, 100% { opacity: 0.25; transform: translateX(-50%) translateY(0); }
		50% { opacity: 0.5; transform: translateX(-50%) translateY(-2px); }
	}
</style>

<script>
	const intro = document.getElementById('intro-screen');
	const seal = document.getElementById('wax-seal');
	const sealCracks = document.getElementById('seal-cracks');
	const flap = document.getElementById('envelope-flap');
	const card = document.getElementById('invitation-card');
	const assembly = document.getElementById('envelope-assembly');
	const shadow = document.getElementById('envelope-shadow');
	const ambientLight = document.getElementById('ambient-light');
	const hint = document.getElementById('tap-hint');

	let opened = false;

	function openEnvelope() {
		if (opened) return;
		opened = true;

		// Hide hint
		if (hint) hint.style.opacity = '0';

		// Brighten ambient light
		ambientLight?.classList.add('bright');

		// Step 1: Crack the seal (0ms)
		sealCracks?.classList.add('visible');

		// Step 2: Break seal apart (400ms)
		setTimeout(() => {
			seal?.classList.add('broken');
		}, 400);

		// Step 3: Open flap (700ms)
		setTimeout(() => {
			flap?.classList.add('open');
		}, 700);

		// Step 4: Card rises out (1300ms)
		setTimeout(() => {
			card?.classList.add('risen');
			shadow?.classList.add('lifted');
		}, 1300);

		// Step 5: Zoom out assembly (3000ms)
		setTimeout(() => {
			assembly?.classList.add('zoom');
		}, 3200);

		// Step 6: Dismiss intro, show quiz (3800ms)
		setTimeout(() => {
			intro?.classList.add('dismissed');
			if (typeof (window as any).showQuizGate === 'function') {
				(window as any).showQuizGate();
			}
		}, 3800);

		// Step 7: Remove from DOM
		setTimeout(() => {
			intro?.remove();
		}, 4500);
	}

	// Lock scroll
	document.body.style.overflow = 'hidden';
	document.documentElement.style.overflow = 'hidden';
	
	// Block touch/wheel scroll events — store globally so QuizGate can remove them
	(window as any).__preventScroll = function(e: Event) {
		e.preventDefault();
	};
	document.addEventListener('wheel', (window as any).__preventScroll, { passive: false });
	document.addEventListener('touchmove', (window as any).__preventScroll, { passive: false });

	// Click / tap to open
	intro?.addEventListener('click', (e) => {
		e.stopPropagation();
		e.stopImmediatePropagation();
		openEnvelope();
	});

	// Also capture at the document level to prevent any stray clicks during animation
	intro?.addEventListener('mouseup', (e) => { e.stopPropagation(); });
	intro?.addEventListener('touchend', (e) => { e.stopPropagation(); });

	// Keyboard accessibility
	intro?.addEventListener('keydown', (e) => {
		if (e.key === 'Enter' || e.key === ' ') {
			e.preventDefault();
			openEnvelope();
		}
	});
</script>
