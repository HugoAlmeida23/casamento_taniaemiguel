---
const date = new Date('2026-06-20T15:00:00');
const formatter = new Intl.DateTimeFormat('pt-PT', { dateStyle: 'long' });
---

<section class="relative overflow-hidden">
	<div class="mx-auto max-w-6xl px-6 py-24 sm:py-32">
		<div class="text-center">
			<p class="text-sm uppercase tracking-wider text-rose-500">Vamos casar</p>
			<h1 class="mt-2 text-4xl font-semibold tracking-tight text-gray-900 sm:text-6xl">Miguel & Tânia</h1>
			<p class="mt-6 text-lg leading-8 text-gray-600">{formatter.format(date)} · Lisboa, Portugal</p>
			<div class="mt-10 flex items-center justify-center gap-x-6">
				<a href="/rsvp" class="rounded-md bg-rose-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-rose-500 focus:outline-none focus:ring-2 focus:ring-rose-600">Confirmar presença</a>
				<a href="#detalhes" class="text-sm font-semibold leading-6 text-gray-900">Detalhes do evento<span aria-hidden="true"> →</span></a>
			</div>
		</div>
	</div>
    
	<div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 bg-gradient-to-b from-rose-50 to-white"></div>
</section>

<section id="detalhes" class="border-t border-gray-200 bg-gray-50">
	<div class="mx-auto max-w-6xl px-6 py-16 grid gap-10 sm:grid-cols-2">
		<div>
			<h2 class="text-2xl font-semibold text-gray-900">Cerimónia</h2>
			<p class="mt-2 text-gray-700">Igreja de São Roque, 15:00</p>
			<p class="mt-2 text-sm text-gray-600">Largo Trindade Coelho, 1200-470 Lisboa</p>
		</div>
		<div>
			<h2 class="text-2xl font-semibold text-gray-900">Copo d'Água</h2>
			<p class="mt-2 text-gray-700">Palácio de Xabregas, 18:00</p>
			<p class="mt-2 text-sm text-gray-600">Rua de Xabregas 22, 1900-440 Lisboa</p>
		</div>
	</div>
</section>
