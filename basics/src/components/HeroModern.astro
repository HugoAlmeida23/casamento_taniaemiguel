---
// Hero section — couple photo background with elegant overlay, inspired by daynight template
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
	<!-- Background image -->
	<div class="absolute inset-0">
		<img 
			src={`${import.meta.env.BASE_URL}/images/background_image.jpg`}
			alt="" 
			class="w-full h-full object-cover"
			loading="eager"
		/>
		<!-- Overlay for readability -->
		<div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/20 to-black/50"></div>
	</div>

	<div class="relative z-10 text-center px-6 max-w-3xl mx-auto">
		<!-- Subtitle -->
		<p class="text-xs md:text-sm uppercase tracking-[0.3em] text-white/70 font-medium mb-6">Vamos casar</p>

		<!-- Names -->
		<h1 class="text-5xl sm:text-6xl md:text-8xl font-light text-white mb-4" style="font-family: 'Playfair Display', serif; letter-spacing: -0.02em;">
			Tânia <span class="italic" style="color: #d4c5a5;">&</span> Miguel
		</h1>

		<!-- Ornament -->
		<div class="flex items-center justify-center gap-3 my-6">
			<span class="w-12 md:w-20 h-px bg-white/30"></span>
			<span class="text-lg">🌿</span>
			<span class="w-12 md:w-20 h-px bg-white/30"></span>
		</div>

		<!-- Date -->
		<p class="text-lg md:text-xl text-white/90 font-light tracking-wide">
			20 de Junho de 2027
		</p>
		<p class="text-sm text-white/60 mt-2">
			Quinta da Lage — Santo Tirso
		</p>

		<!-- Scroll hint -->
		<div class="mt-16 animate-bounce">
			<svg class="w-5 h-5 mx-auto text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
			</svg>
		</div>
	</div>
</section>
