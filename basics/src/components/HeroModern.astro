---
// Elegant hero section - clean, minimal, serif typography
---

<section class="relative min-h-screen flex items-center justify-center bg-[#faf9f7] overflow-hidden">
	<!-- Subtle background texture -->
	<div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23000000&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

	<div class="relative z-10 text-center px-6 max-w-3xl mx-auto">
		<!-- Subtitle -->
		<p class="section-subtitle mb-6">Vamos casar</p>

		<!-- Names -->
		<h1 class="text-5xl sm:text-6xl md:text-8xl font-light text-gray-900 mb-2" style="font-family: 'Playfair Display', serif; letter-spacing: -0.02em;">
			Tânia <span class="text-rose-400 italic">&</span> Miguel
		</h1>

		<!-- Ornament -->
		<div class="ornament">
			<svg class="w-4 h-4 text-rose-400" fill="currentColor" viewBox="0 0 24 24">
				<path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
			</svg>
		</div>

		<!-- Date -->
		<p class="text-lg md:text-xl text-gray-500 font-light tracking-wide">
			20 de Junho de 2027
		</p>
		<p class="text-sm text-gray-400 mt-2">
			Quinta da Lage - Santo Tirso
		</p>

		<!-- Scroll hint -->
		<div class="mt-16 animate-bounce">
			<svg class="w-5 h-5 mx-auto text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
			</svg>
		</div>
	</div>
</section>
