---
// Gifts / Honeymoon fund section
---

<section class="wedding-section bg-white">
	<div class="max-w-3xl mx-auto">
		<div class="section-header">
			<p class="section-subtitle">Um gesto carinhoso</p>
			<h2 class="section-title">Lua de Mel</h2>
			<div class="ornament">
				<svg class="w-4 h-4 text-rose-400" fill="currentColor" viewBox="0 0 24 24">
					<path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
				</svg>
			</div>
		</div>

		<div class="text-center mb-10">
			<p class="text-gray-600 leading-relaxed max-w-xl mx-auto">
				A vossa presença é o maior presente de todos. Para quem quiser contribuir 
				para a nossa lua de mel na grande <strong>Trofa</strong> e <strong>Ribeirão</strong> 🌴, 
				pode fazê-lo das seguintes formas:
			</p>
		</div>

		<!-- Payment options -->
		<div class="grid sm:grid-cols-2 gap-4 max-w-xl mx-auto">
			<!-- MBWAY -->
			<div class="wedding-card text-center">
				<div class="text-3xl mb-3">💳</div>
				<h4 class="text-sm uppercase tracking-[0.15em] text-gray-400 font-medium mb-4">MBWAY</h4>
				<div class="space-y-3">
					<div>
						<p class="text-xs text-gray-400">Tânia</p>
						<p class="font-mono text-gray-900 font-medium">916 702 436</p>
					</div>
					<div>
						<p class="text-xs text-gray-400">Miguel</p>
						<p class="font-mono text-gray-900 font-medium">910 661 162</p>
					</div>
				</div>
			</div>

			<!-- Bank Transfer -->
			<div class="wedding-card text-center">
				<div class="text-3xl mb-3">🏦</div>
				<h4 class="text-sm uppercase tracking-[0.15em] text-gray-400 font-medium mb-4">Transferência</h4>
				<div>
					<p class="text-xs text-gray-400 mb-2">IBAN</p>
					<p class="font-mono text-sm text-gray-900 font-medium break-all">
						PT50 0269 0195 00204538094 22
					</p>
				</div>
			</div>
		</div>

		<!-- Bali image -->
		<div class="mt-10 rounded-3xl overflow-hidden shadow-sm max-w-md mx-auto">
			<img 
				src={`${import.meta.env.BASE_URL}/images/bali.jpg`}
				alt="Bali - Lua de mel" 
				class="w-full h-48 object-cover"
				loading="lazy"
			/>
		</div>
	</div>
</section>
