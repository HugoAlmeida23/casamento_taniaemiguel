---
// Programa do dia — Timeline with olive/beige palette
const events = [
	{ time: '15:30', title: 'Cerimónia Religiosa', desc: 'Igreja Paroquial de Santo Tirso' },
	{ time: '17:00', title: 'Chegada à Quinta & Cocktail', desc: 'Receção e cocktail de boas-vindas' },
	{ time: '19:00', title: 'Jantar', desc: 'Jantar ao ar livre na quinta' },
	{ time: '22:00', title: 'Festa & Dança', desc: 'Vamos dançar a noite toda!' },
	{ time: '02:00', title: 'Última Dança', desc: 'Despedida e memórias bonitas' },
];
---

<section class="wedding-section bg-[#faf7f0]">
	<div class="max-w-3xl mx-auto">
		<div class="section-header">
			<p class="section-subtitle">Programa do dia</p>
			<h2 class="section-title">O que planeámos para vocês</h2>
			<div class="ornament">
				<span class="text-lg">🌿</span>
			</div>
		</div>

		<!-- Timeline -->
		<div class="relative">
			<!-- Vertical line -->
			<div class="absolute left-[18px] md:left-1/2 top-0 bottom-0 w-px bg-beige-300 -translate-x-1/2"></div>

			<div class="space-y-10">
				{events.map((event, i) => (
					<div class={`relative flex items-start gap-6 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
						<!-- Dot -->
						<div class="absolute left-[18px] md:left-1/2 -translate-x-1/2 z-10">
							<div class="w-3 h-3 rounded-full bg-olive-500 border-2 border-white shadow-sm"></div>
						</div>

						<!-- Content -->
						<div class={`ml-10 md:ml-0 md:w-[calc(50%-2rem)] ${i % 2 === 0 ? 'md:pr-8 md:text-right' : 'md:pl-8 md:text-left'}`}>
							<span class="text-xs uppercase tracking-[0.2em] text-olive-500 font-medium">{event.time}</span>
							<h3 class="text-lg font-medium text-gray-900 mt-1" style="font-family: 'Playfair Display', serif;">
								{event.title}
							</h3>
							<p class="text-sm text-gray-500 mt-1">{event.desc}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</div>
</section>
