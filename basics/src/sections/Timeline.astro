---
// Order of the Day - Timeline section
const events = [
	{ time: '15:30', title: 'Chegada & Boas-vindas', desc: 'Receção e cocktail de boas-vindas na quinta' },
	{ time: '16:00', title: 'Cerimónia Civil', desc: 'O momento mais especial do dia' },
	{ time: '17:00', title: 'Cocktail & Jantar', desc: 'Jantar ao ar livre sob as estrelas' },
	{ time: '22:00', title: 'Festa', desc: 'Vamos dançar a noite toda!' },
	{ time: '02:00', title: 'Última Dança', desc: 'Despedida e memórias bonitas' },
];
---

<section class="wedding-section bg-[#faf9f7]">
	<div class="max-w-3xl mx-auto">
		<div class="section-header">
			<p class="section-subtitle">Programa do dia</p>
			<h2 class="section-title">O que planeámos para vocês</h2>
			<div class="ornament">
				<svg class="w-4 h-4 text-rose-400" fill="currentColor" viewBox="0 0 24 24">
					<path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
				</svg>
			</div>
		</div>

		<!-- Timeline -->
		<div class="relative">
			<!-- Vertical line -->
			<div class="absolute left-[18px] md:left-1/2 top-0 bottom-0 w-px bg-gray-200 -translate-x-1/2"></div>

			<div class="space-y-10">
				{events.map((event, i) => (
					<div class={`relative flex items-start gap-6 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
						<!-- Dot -->
						<div class="absolute left-[18px] md:left-1/2 -translate-x-1/2 z-10">
							<div class="w-3 h-3 rounded-full bg-rose-400 border-2 border-white shadow-sm"></div>
						</div>

						<!-- Content -->
						<div class={`ml-10 md:ml-0 md:w-[calc(50%-2rem)] ${i % 2 === 0 ? 'md:pr-8 md:text-right' : 'md:pl-8 md:text-left'}`}>
							<span class="text-xs uppercase tracking-[0.2em] text-rose-400 font-medium">{event.time}</span>
							<h3 class="text-lg font-medium text-gray-900 mt-1" style="font-family: 'Playfair Display', serif;">
								{event.title}
							</h3>
							<p class="text-sm text-gray-500 mt-1">{event.desc}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</div>
</section>
