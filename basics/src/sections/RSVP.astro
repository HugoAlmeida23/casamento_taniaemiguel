---
// RSVP section — olive/beige palette
---

<section id="rsvp" class="wedding-section bg-[#faf7f0]">
	<div class="max-w-2xl mx-auto">
		<div class="section-header">
			<p class="section-subtitle">Esperamos por vocês</p>
			<h2 class="section-title">Confirmações</h2>
			<div class="ornament">
				<span class="text-lg">🌿</span>
			</div>
		</div>

		<div class="wedding-card">
			<form id="rsvp-form" class="space-y-5" autocomplete="on">
				<!-- Nome -->
				<div>
					<label for="nome" class="rsvp-label">O teu nome *</label>
					<input type="text" id="nome" name="nome" required class="rsvp-input" placeholder="O teu nome completo" />
				</div>

				<!-- Telefone -->
				<div>
					<label for="telefone" class="rsvp-label">Telemóvel *</label>
					<input type="tel" id="telefone" name="telefone" required class="rsvp-input" placeholder="+351 912 345 678" />
				</div>

				<!-- Quantas pessoas -->
				<div>
					<label class="rsvp-label">Quantas pessoas vêm contigo? (incluindo-te)</label>
					<div class="grid grid-cols-4 gap-2" id="guest-count-options">
						<label class="rsvp-option-label">
							<input type="radio" name="numGuests" value="1" checked class="sr-only peer" />
							<div class="rsvp-count-option peer-checked:border-olive-500 peer-checked:bg-olive-50 peer-checked:text-olive-700">
								<span class="text-lg font-medium">1</span>
							</div>
						</label>
						<label class="rsvp-option-label">
							<input type="radio" name="numGuests" value="2" class="sr-only peer" />
							<div class="rsvp-count-option peer-checked:border-olive-500 peer-checked:bg-olive-50 peer-checked:text-olive-700">
								<span class="text-lg font-medium">2</span>
							</div>
						</label>
						<label class="rsvp-option-label">
							<input type="radio" name="numGuests" value="3" class="sr-only peer" />
							<div class="rsvp-count-option peer-checked:border-olive-500 peer-checked:bg-olive-50 peer-checked:text-olive-700">
								<span class="text-lg font-medium">3</span>
							</div>
						</label>
						<label class="rsvp-option-label">
							<input type="radio" name="numGuests" value="4+" class="sr-only peer" />
							<div class="rsvp-count-option peer-checked:border-olive-500 peer-checked:bg-olive-50 peer-checked:text-olive-700">
								<span class="text-lg font-medium">4+</span>
							</div>
						</label>
					</div>
				</div>

				<!-- Dynamic guest names -->
				<div id="guests-container" class="space-y-3 hidden">
					<label class="rsvp-label">Nomes dos acompanhantes</label>
					<div id="guests-list" class="space-y-2"></div>
				</div>

				<!-- Crianças -->
				<div id="children-section" class="hidden">
					<label class="rsvp-label">Alguma criança no grupo?</label>
					<div class="grid grid-cols-2 gap-3">
						<label class="rsvp-option-label">
							<input type="radio" name="children" value="no" checked class="sr-only peer" />
							<div class="rsvp-option-sm peer-checked:border-olive-500 peer-checked:bg-olive-50">
								<span class="text-sm">Não</span>
							</div>
						</label>
						<label class="rsvp-option-label">
							<input type="radio" name="children" value="yes" class="sr-only peer" />
							<div class="rsvp-option-sm peer-checked:border-olive-500 peer-checked:bg-olive-50">
								<span class="text-sm">Sim</span>
							</div>
						</label>
					</div>
				</div>

				<!-- Nomes crianças -->
				<div id="children-names-section" class="hidden">
					<label for="childrenNames" class="rsvp-label">Nomes e idades das crianças</label>
					<input type="text" id="childrenNames" name="childrenNames" class="rsvp-input" placeholder="Ex: Maria (3 anos), João (7 anos)" />
				</div>

				<!-- Restrições -->
				<div>
					<label for="restricoes" class="rsvp-label">Alergias ou restrições alimentares</label>
					<textarea id="restricoes" name="restricoes" rows="2" class="rsvp-input resize-none" placeholder="Vegetariano, alergias, etc. (opcional)"></textarea>
				</div>

				<!-- Mensagem -->
				<div>
					<label for="mensagem" class="rsvp-label">Mensagem para os noivos (opcional)</label>
					<textarea id="mensagem" name="mensagem" rows="2" class="rsvp-input resize-none" placeholder="Uma palavrinha para nós..."></textarea>
				</div>

				<!-- Submit -->
				<div class="pt-3">
					<button 
						type="submit" 
						id="submit-btn"
						class="w-full py-4 px-6 bg-olive-600 hover:bg-olive-700 text-white text-sm font-medium uppercase tracking-[0.15em] rounded-full transition-all duration-300 hover:shadow-lg"
					>
						Enviar Confirmação
					</button>
				</div>

				<!-- Message -->
				<div id="rsvp-message" class="hidden rounded-xl p-4 text-center text-sm"></div>
			</form>
		</div>
	</div>
</section>

<style>
	.rsvp-label {
		@apply block text-xs uppercase tracking-[0.15em] text-olive-500 font-medium mb-2;
	}

	.rsvp-input {
		@apply w-full px-4 py-3 border border-beige-300 rounded-xl text-gray-900 bg-white text-sm transition-all duration-200;
	}

	.rsvp-input:focus {
		@apply outline-none border-olive-400 ring-3 ring-olive-100;
	}

	.rsvp-input::placeholder {
		@apply text-gray-300;
	}

	.rsvp-option-label {
		@apply cursor-pointer;
	}

	.rsvp-option {
		@apply flex flex-col items-center justify-center p-4 border-2 border-beige-200 rounded-xl transition-all duration-200 text-center;
	}

	.rsvp-option-sm {
		@apply flex items-center justify-center p-3 border-2 border-beige-200 rounded-xl transition-all duration-200 text-center;
	}

	.rsvp-count-option {
		@apply flex items-center justify-center p-3 border-2 border-beige-200 rounded-xl transition-all duration-200 text-center text-gray-600;
	}

	#rsvp-message.success {
		@apply bg-olive-50 text-olive-700 border border-olive-200;
	}

	#rsvp-message.error {
		@apply bg-red-50 text-red-700 border border-red-200;
	}

	#guests-container,
	#children-section,
	#children-names-section {
		transition: opacity 0.3s ease, transform 0.3s ease;
	}

	#guests-container.hidden,
	#children-section.hidden,
	#children-names-section.hidden {
		opacity: 0;
		transform: translateY(-4px);
		pointer-events: none;
		position: absolute;
		visibility: hidden;
	}

	#guests-container:not(.hidden),
	#children-section:not(.hidden),
	#children-names-section:not(.hidden) {
		opacity: 1;
		transform: translateY(0);
		position: relative;
		visibility: visible;
	}
</style>

<script>
	const form = document.getElementById('rsvp-form') as HTMLFormElement;
	const message = document.getElementById('rsvp-message') as HTMLDivElement;
	const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
	const guestsContainer = document.getElementById('guests-container') as HTMLDivElement;
	const guestsList = document.getElementById('guests-list') as HTMLDivElement;
	const childrenSection = document.getElementById('children-section') as HTMLDivElement;
	const childrenNamesSection = document.getElementById('children-names-section') as HTMLDivElement;

	const guestRadios = document.querySelectorAll('input[name="numGuests"]');
	guestRadios.forEach(radio => {
		radio.addEventListener('change', () => {
			const value = (radio as HTMLInputElement).value;
			updateGuestFields(value);
		});
	});

	function updateGuestFields(value: string) {
		const num = value === '4+' ? 4 : parseInt(value);

		if (num <= 1) {
			guestsContainer.classList.add('hidden');
			childrenSection.classList.add('hidden');
			childrenNamesSection.classList.add('hidden');
		} else {
			guestsContainer.classList.remove('hidden');
			childrenSection.classList.remove('hidden');

			guestsList.innerHTML = '';
			for (let i = 1; i < num; i++) {
				const input = document.createElement('input');
				input.type = 'text';
				input.name = `guest_${i}`;
				input.placeholder = `Nome do acompanhante ${i}`;
				input.className = 'w-full px-4 py-3 border border-beige-300 rounded-xl text-gray-900 bg-white text-sm transition-all duration-200 focus:outline-none focus:border-olive-400 focus:ring-3 focus:ring-olive-100';
				guestsList.appendChild(input);
			}

			if (value === '4+') {
				const note = document.createElement('p');
				note.className = 'text-xs text-gray-400 italic mt-1';
				note.textContent = 'Se forem mais de 4, escreve todos os nomes separados por vírgula no último campo.';
				guestsList.appendChild(note);
			}
		}
	}

	const childrenRadios = document.querySelectorAll('input[name="children"]');
	childrenRadios.forEach(radio => {
		radio.addEventListener('change', () => {
			const value = (radio as HTMLInputElement).value;
			if (value === 'yes') {
				childrenNamesSection.classList.remove('hidden');
			} else {
				childrenNamesSection.classList.add('hidden');
			}
		});
	});

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();

		message.classList.add('hidden');
		message.classList.remove('success', 'error');

		submitBtn.disabled = true;
		const originalText = submitBtn.textContent;
		submitBtn.textContent = 'A enviar...';

		const formData = new FormData(form);
		
		const guests: string[] = [];
		const numGuests = formData.get('numGuests') as string;
		const num = numGuests === '4+' ? 4 : parseInt(numGuests);
		for (let i = 1; i < num; i++) {
			const name = formData.get(`guest_${i}`) as string;
			if (name?.trim()) guests.push(name.trim());
		}

		const payload = {
			nome: formData.get('nome'),
			telefone: formData.get('telefone'),
			attending: true,
			numGuests: numGuests,
			guests: guests,
			children: formData.get('children') === 'yes',
			childrenNames: formData.get('childrenNames') || null,
			restricoes: formData.get('restricoes') || null,
			mensagem: formData.get('mensagem') || null,
		};

		try {
			const resp = await fetch('/api/rsvp', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(payload),
			});

			if (!resp.ok) throw new Error('API error');

			form.reset();
			guestsContainer.classList.add('hidden');
			childrenSection.classList.add('hidden');
			childrenNamesSection.classList.add('hidden');
			guestsList.innerHTML = '';

			message.classList.remove('hidden');
			message.classList.add('success');
			message.textContent = '🌿 Obrigado! Recebemos a vossa confirmação. Mal podemos esperar!';
		} catch (err) {
			console.error(err);
			message.classList.remove('hidden');
			message.classList.add('error');
			message.textContent = 'Ocorreu um erro. Tentem novamente ou contactem-nos diretamente.';
		} finally {
			submitBtn.disabled = false;
			submitBtn.textContent = originalText;
		}
	});
</script>
