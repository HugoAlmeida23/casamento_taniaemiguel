---
// RSVP section — companions added via "+ Adulto" / "+ Criança" buttons
---

<section id="rsvp" class="wedding-section bg-[#faf7f0]">
	<div class="max-w-2xl mx-auto">
		<div class="section-header">
			<p class="section-subtitle">Esperamos por vocês</p>
			<h2 class="section-title">Confirmações</h2>
			<div class="ornament">
				<span class="text-lg">🌿</span>
			</div>
		</div>

		<div class="wedding-card">
			<form id="rsvp-form" class="space-y-5" autocomplete="on">
				<!-- Nome -->
				<div>
					<label for="nome" class="rsvp-label">O teu nome *</label>
					<input type="text" id="nome" name="nome" required class="rsvp-input" placeholder="O teu nome completo" />
				</div>

				<!-- Telefone -->
				<div>
					<label for="telefone" class="rsvp-label">Telemóvel *</label>
					<input type="tel" id="telefone" name="telefone" required class="rsvp-input" placeholder="+351 912 345 678" />
				</div>

				<!-- Restrições do próprio -->
				<div>
					<label for="restricoes" class="rsvp-label">As tuas alergias ou restrições alimentares</label>
					<input type="text" id="restricoes" name="restricoes" class="rsvp-input" placeholder="Vegetariano, alergias, etc. (opcional)" />
				</div>

				<!-- Acompanhantes section -->
				<div>
					<label class="rsvp-label">Acompanhantes</label>
					<p class="text-xs text-gray-400 mb-3">Adiciona as pessoas que vêm contigo e indica alergias caso tenham.</p>
					
					<!-- List of companions -->
					<div id="companions-list" class="space-y-3 mb-4"></div>

					<!-- Add buttons -->
					<div class="flex gap-3">
						<button 
							type="button" 
							id="add-adult-btn"
							class="add-companion-btn"
						>
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
							</svg>
							Adulto
						</button>
						<button 
							type="button" 
							id="add-child-btn"
							class="add-companion-btn"
						>
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
							</svg>
							Criança
						</button>
					</div>
				</div>

				<!-- Mensagem -->
				<div>
					<label for="mensagem" class="rsvp-label">Mensagem para os noivos (opcional)</label>
					<textarea id="mensagem" name="mensagem" rows="2" class="rsvp-input resize-none" placeholder="Uma palavrinha para nós..."></textarea>
				</div>

				<!-- Submit -->
				<div class="pt-3">
					<button 
						type="submit" 
						id="submit-btn"
						class="w-full py-4 px-6 bg-olive-600 hover:bg-olive-700 text-white text-sm font-medium uppercase tracking-[0.15em] rounded-full transition-all duration-300 hover:shadow-lg"
					>
						Enviar Confirmação
					</button>
				</div>

				<!-- Message -->
				<div id="rsvp-message" class="hidden rounded-xl p-4 text-center text-sm"></div>
			</form>
		</div>
	</div>
</section>

<style>
	.rsvp-label {
		@apply block text-xs uppercase tracking-[0.15em] text-olive-500 font-medium mb-2;
	}

	.rsvp-input {
		@apply w-full px-4 py-3 border border-beige-300 rounded-xl text-gray-900 bg-white text-sm transition-all duration-200;
	}

	.rsvp-input:focus {
		@apply outline-none border-olive-400 ring-3 ring-olive-100;
	}

	.rsvp-input::placeholder {
		@apply text-gray-300;
	}

	.add-companion-btn {
		@apply inline-flex items-center gap-2 px-4 py-2.5 border-2 border-dashed border-beige-300 rounded-xl text-sm font-medium text-olive-600 transition-all duration-200;
	}

	.add-companion-btn:hover {
		@apply border-olive-400 bg-olive-50;
	}

	.companion-card {
		@apply relative p-4 border border-beige-200 rounded-xl bg-white/60 space-y-2;
		animation: slideIn 0.3s ease;
	}

	@keyframes slideIn {
		from { opacity: 0; transform: translateY(-8px); }
		to { opacity: 1; transform: translateY(0); }
	}

	.companion-remove {
		@apply absolute top-3 right-3 w-6 h-6 flex items-center justify-center rounded-full text-gray-400 hover:text-red-500 hover:bg-red-50 transition-colors;
	}

	.companion-badge {
		@apply inline-block text-[0.6rem] uppercase tracking-wider font-semibold px-2 py-0.5 rounded-full;
	}

	.companion-badge.adult {
		@apply bg-olive-100 text-olive-700;
	}

	.companion-badge.child {
		@apply bg-beige-200 text-beige-800;
	}

	#rsvp-message.success {
		@apply bg-olive-50 text-olive-700 border border-olive-200;
	}

	#rsvp-message.error {
		@apply bg-red-50 text-red-700 border border-red-200;
	}
</style>

<script>
	const form = document.getElementById('rsvp-form') as HTMLFormElement;
	const message = document.getElementById('rsvp-message') as HTMLDivElement;
	const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
	const companionsList = document.getElementById('companions-list') as HTMLDivElement;
	const addAdultBtn = document.getElementById('add-adult-btn') as HTMLButtonElement;
	const addChildBtn = document.getElementById('add-child-btn') as HTMLButtonElement;

	let companionCount = 0;

	function addCompanion(type: 'adult' | 'child') {
		companionCount++;
		const id = companionCount;

		const card = document.createElement('div');
		card.className = 'companion-card';
		card.dataset.companionId = id.toString();
		card.dataset.type = type;

		const badgeClass = type === 'adult' ? 'adult' : 'child';
		const badgeText = type === 'adult' ? 'Adulto' : 'Criança';

		card.innerHTML = `
			<button type="button" class="companion-remove" aria-label="Remover" data-remove="${id}">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
				</svg>
			</button>
			<span class="companion-badge ${badgeClass}">${badgeText}</span>
			<input 
				type="text" 
				name="companion_name_${id}" 
				placeholder="${type === 'child' ? 'Nome e idade (ex: Maria, 3 anos)' : 'Nome'}" 
				class="w-full px-4 py-3 border border-beige-300 rounded-xl text-gray-900 bg-white text-sm transition-all duration-200 focus:outline-none focus:border-olive-400 focus:ring-3 focus:ring-olive-100"
			/>
			<input 
				type="text" 
				name="companion_allergy_${id}" 
				placeholder="Alergias / restrições alimentares (opcional)" 
				class="w-full px-4 py-3 border border-beige-300 rounded-xl text-gray-900 bg-white text-sm transition-all duration-200 focus:outline-none focus:border-olive-400 focus:ring-3 focus:ring-olive-100"
			/>
		`;

		companionsList.appendChild(card);

		// Attach remove handler
		const removeBtn = card.querySelector(`[data-remove="${id}"]`);
		removeBtn?.addEventListener('click', () => {
			card.style.opacity = '0';
			card.style.transform = 'translateY(-8px)';
			card.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
			setTimeout(() => card.remove(), 200);
		});
	}

	addAdultBtn?.addEventListener('click', () => addCompanion('adult'));
	addChildBtn?.addEventListener('click', () => addCompanion('child'));

	// Form submit
	form?.addEventListener('submit', async (e) => {
		e.preventDefault();

		message.classList.add('hidden');
		message.classList.remove('success', 'error');

		submitBtn.disabled = true;
		const originalText = submitBtn.textContent;
		submitBtn.textContent = 'A enviar...';

		const formData = new FormData(form);

		// Collect companions
		const companions: {name: string, type: string, allergy: string}[] = [];
		const cards = companionsList.querySelectorAll('.companion-card');
		cards.forEach(card => {
			const cardEl = card as HTMLElement;
			const id = cardEl.dataset.companionId;
			const type = cardEl.dataset.type || 'adult';
			const name = formData.get(`companion_name_${id}`) as string;
			const allergy = formData.get(`companion_allergy_${id}`) as string;
			if (name?.trim()) {
				companions.push({ 
					name: name.trim(), 
					type, 
					allergy: allergy?.trim() || '' 
				});
			}
		});

		const payload = {
			nome: formData.get('nome'),
			telefone: formData.get('telefone'),
			attending: true,
			restricoes: formData.get('restricoes') || null,
			companions: companions,
			mensagem: formData.get('mensagem') || null,
		};

		try {
			const { createClient } = await import('@supabase/supabase-js');
			const supabaseUrl = (import.meta as any).env.PUBLIC_SUPABASE_URL;
			const supabaseKey = (import.meta as any).env.PUBLIC_SUPABASE_ANON_KEY;
			const supabase = createClient(supabaseUrl, supabaseKey);

			const { error } = await supabase
				.from('guests')
				.insert({
					nome: payload.nome,
					telefone: payload.telefone,
					acompanha: payload.companions.length > 0 ? 1 : 0,
					restricoes: payload.restricoes || null,
					companions: payload.companions,
					mensagem: payload.mensagem || null,
				});

			if (error) throw new Error(error.message);

			form.reset();
			companionsList.innerHTML = '';
			companionCount = 0;

			message.classList.remove('hidden');
			message.classList.add('success');
			message.textContent = '🌿 Obrigado! Recebemos a vossa confirmação. Mal podemos esperar!';
		} catch (err) {
			console.error(err);
			message.classList.remove('hidden');
			message.classList.add('error');
			message.textContent = 'Ocorreu um erro. Tentem novamente ou contactem-nos diretamente.';
		} finally {
			submitBtn.disabled = false;
			submitBtn.textContent = originalText;
		}
	});
</script>
