---
// RSVP section with form
---

<section id="rsvp" class="content-section py-20">
	<div class="max-w-4xl mx-auto px-4">
		<div class="text-center mb-16">
			<div class="inline-flex items-center justify-center w-16 h-16 bg-rose-100 rounded-full mb-6">
				<svg class="w-8 h-8 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
				</svg>
			</div>
			<h2 class="text-4xl md:text-5xl font-light text-gray-800 mb-4">
				Confirmação de Presença
			</h2>
			<div class="w-24 h-px bg-rose-400 mx-auto mb-8"></div>
			<p class="text-lg text-gray-600 max-w-2xl mx-auto">
				A vossa presença é o melhor presente que podemos receber. 
				Por favor, confirmem a vossa participação até 15 de agosto de 2025.
			</p>
		</div>
		
		<div class="bg-white rounded-lg shadow-lg p-8 md:p-12">
			<form id="rsvp-form" class="space-y-6">
				<div class="grid md:grid-cols-2 gap-6">
					<div>
						<label for="firstName" class="block text-sm font-medium text-gray-700 mb-2">
							Primeiro Nome *
						</label>
						<input 
							type="text" 
							id="firstName" 
							name="firstName" 
							required 
							class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-colors"
							placeholder="O teu primeiro nome"
						>
					</div>
					<div>
						<label for="lastName" class="block text-sm font-medium text-gray-700 mb-2">
							Último Nome *
						</label>
						<input 
							type="text" 
							id="lastName" 
							name="lastName" 
							required 
							class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-colors"
							placeholder="O teu último nome"
						>
					</div>
				</div>
				
				<div>
					<label for="email" class="block text-sm font-medium text-gray-700 mb-2">
						Email *
					</label>
					<input 
						type="email" 
						id="email" 
						name="email" 
						required 
						class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-colors"
						placeholder="o.teu@email.com"
					>
				</div>
				
				<div>
					<label for="guests" class="block text-sm font-medium text-gray-700 mb-2">
						Número de acompanhantes
					</label>
					<select 
						id="guests" 
						name="guests" 
						class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-colors"
					>
						<option value="0">Apenas eu</option>
						<option value="1">Eu + 1 acompanhante</option>
						<option value="2">Eu + 2 acompanhantes</option>
						<option value="3">Eu + 3 acompanhantes</option>
						<option value="4">Eu + 4 acompanhantes</option>
					</select>
				</div>
				
				<div>
					<label class="block text-sm font-medium text-gray-700 mb-4">
						Consegues estar presente? *
					</label>
					<div class="space-y-3">
						<label class="flex items-center">
							<input 
								type="radio" 
								name="attendance" 
								value="yes" 
								required 
								class="h-4 w-4 text-rose-500 focus:ring-rose-500 border-gray-300"
							>
							<span class="ml-3 text-gray-700">Sim, estarei presente! 🎉</span>
						</label>
						<label class="flex items-center">
							<input 
								type="radio" 
								name="attendance" 
								value="no" 
								required 
								class="h-4 w-4 text-rose-500 focus:ring-rose-500 border-gray-300"
							>
							<span class="ml-3 text-gray-700">Infelizmente não posso comparecer 😔</span>
						</label>
					</div>
				</div>
				
				<div>
					<label for="dietary" class="block text-sm font-medium text-gray-700 mb-2">
						Restrições alimentares ou observações
					</label>
					<textarea 
						id="dietary" 
						name="dietary" 
						rows="4" 
						class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-colors resize-none"
						placeholder="Deixa-nos saber se tens alguma restrição alimentar ou algo que queiras partilhar connosco..."
					></textarea>
				</div>
				
				<div class="text-center pt-6">
					<button 
						type="submit" 
						class="bg-rose-500 hover:bg-rose-600 text-white font-medium px-8 py-4 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-rose-500 focus:ring-offset-2"
					>
						Confirmar Presença
					</button>
				</div>
			</form>
		</div>
	</div>
</section>

<script>
	document.getElementById('rsvp-form')?.addEventListener('submit', function(e) {
		e.preventDefault();
		
		// Show success message
		const form = e.target as HTMLFormElement;
		const formData = new FormData(form);
		
		// Simple success feedback
		alert('Obrigado pela confirmação! Recebemos a tua resposta e entraremos em contacto em breve.');
		
		// Reset form
		form.reset();
	});
</script>
