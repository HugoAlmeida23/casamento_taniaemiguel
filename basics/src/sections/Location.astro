---
// Location and accommodation section
---

<section id="location" class="content-section py-20">
	<div class="max-w-6xl mx-auto px-4">
		<div class="text-center mb-16">
			<div class="inline-flex items-center justify-center w-16 h-16 bg-white/20 rounded-full mb-6 backdrop-blur-sm">
				<svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
				</svg>
			</div>
			<h2 class="text-4xl md:text-5xl font-light text-white mb-4 drop-shadow-lg">
				Onde ficar e como chegar
			</h2>
			<div class="w-24 h-px bg-white/60 mx-auto"></div>
		</div>
		
		<div class="grid lg:grid-cols-2 gap-12">
			<!-- Location Info -->
			<div>
				<div class="bg-white/15 backdrop-blur-md rounded-2xl p-8 border border-white/20 mb-8">
					<div class="text-center mb-6">
						<div class="inline-flex items-center justify-center w-12 h-12 bg-white/20 rounded-full mb-4">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
							</svg>
						</div>
						<h3 class="text-2xl font-medium text-white mb-2 drop-shadow-md">
							Localização da cerimónia
						</h3>
					</div>
					
					<div class="bg-white/10 rounded-xl p-6 mb-6 border border-white/10">
						<h4 class="text-xl font-semibold text-white mb-4 drop-shadow-md text-center">
							📍 Quinta de Cima - No Campo é Assim
						</h4>
						<div class="space-y-4 text-white/90 drop-shadow-md">
							<div class="flex items-start">
								<svg class="w-5 h-5 text-white mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
								</svg>
								<div>
									<p class="font-medium text-white">Endereço completo</p>
									<p class="text-white/80">Rua da Quinta, 123<br>4000-000 Porto, Portugal</p>
								</div>
							</div>
							<div class="flex items-center">
								<svg class="w-5 h-5 text-white mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
								</svg>
								<span class="text-white/90">Cerca de 30 minutos do centro do Porto</span>
							</div>
						</div>
					</div>
					
					<div class="flex flex-col sm:flex-row gap-3">
						<a 
							href="https://maps.app.goo.gl/wSMw4FA34gZoiBcf7" 
							target="_blank"
							class="flex-1 inline-flex items-center justify-center px-4 py-3 bg-white/20 hover:bg-white/30 text-white font-medium rounded-lg transition-all backdrop-blur-sm border border-white/20"
						>
							<svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
							</svg>
							Abrir no Google Maps
						</a>
						<button 
							onclick="navigator.share({title: 'Localização do Casamento', text: 'Quinta de Cima - No Campo é Assim', url: 'https://maps.app.goo.gl/wSMw4FA34gZoiBcf7'})"
							class="flex-1 inline-flex items-center justify-center px-4 py-3 bg-white/10 hover:bg-white/20 text-white font-medium rounded-lg transition-all backdrop-blur-sm border border-white/20"
						>
							<svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z"></path>
							</svg>
							Partilhar
						</button>
					</div>
				</div>
				
				<!-- Transportation Tips -->
				<div class="bg-white/10 backdrop-blur-md rounded-xl p-6 border border-white/20">
					<h5 class="font-semibold text-white mb-4 flex items-center drop-shadow-md">
						<svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
						</svg>
						🚗 Como chegar
					</h5>
					<ul class="space-y-3 text-white/90 drop-shadow-md">
						<li class="flex items-start">
							<span class="w-2 h-2 bg-white/60 rounded-full mt-2 mr-3 flex-shrink-0"></span>
							<span><strong>De carro:</strong> Estacionamento gratuito disponível no local</span>
						</li>
						<li class="flex items-start">
							<span class="w-2 h-2 bg-white/60 rounded-full mt-2 mr-3 flex-shrink-0"></span>
							<span><strong>Transporte público:</strong> Comboio até à estação + táxi (15 min)</span>
						</li>
						<li class="flex items-start">
							<span class="w-2 h-2 bg-white/60 rounded-full mt-2 mr-3 flex-shrink-0"></span>
							<span><strong>Táxi/Uber:</strong> Aproximadamente 25€ desde o centro do Porto</span>
						</li>
					</ul>
				</div>
			</div>
			
			<!-- Accommodation -->
			<div>
				<div class="bg-white/15 backdrop-blur-md rounded-2xl p-8 border border-white/20">
					<div class="text-center mb-6">
						<div class="inline-flex items-center justify-center w-12 h-12 bg-white/20 rounded-full mb-4">
							<span class="text-xl">🏨</span>
						</div>
						<h3 class="text-2xl font-medium text-white mb-2 drop-shadow-md">
							Onde ficar
						</h3>
						<p class="text-white/90 drop-shadow-md">
							Para os nossos convidados que vêm de longe, aqui ficam algumas sugestões 
							de alojamento na zona, desde hotéis a quintas rurais encantadoras.
						</p>
					</div>
					
					<div class="space-y-4">
						<!-- Hotel Option 1 -->
						<div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:bg-white/15 transition-all">
							<div class="flex justify-between items-start mb-3">
								<h4 class="text-lg font-semibold text-white drop-shadow-md">🏡 Hotel Rural Quinta do Vale</h4>
								<span class="bg-green-400/30 text-white text-xs font-medium px-3 py-1 rounded-full backdrop-blur-sm">Recomendado</span>
							</div>
							<p class="text-white/90 text-sm mb-4 drop-shadow-md">
								A apenas 10 minutos da quinta. Ambiente rural autêntico com quartos 
								confortáveis e pequeno-almoço incluído.
							</p>
							<div class="flex items-center justify-between">
								<span class="text-white font-semibold drop-shadow-md">A partir de 80€/noite</span>
								<a href="#" class="text-white/80 hover:text-white text-sm font-medium drop-shadow-md">
									Ver disponibilidade →
								</a>
							</div>
						</div>
						
						<!-- Hotel Option 2 -->
						<div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:bg-white/15 transition-all">
							<h4 class="text-lg font-semibold text-white mb-3 drop-shadow-md">🏛️ Pousada Histórica do Porto</h4>
							<p class="text-white/90 text-sm mb-4 drop-shadow-md">
								No centro histórico do Porto. Perfeita para quem quer explorar a cidade 
								antes ou depois do casamento.
							</p>
							<div class="flex items-center justify-between">
								<span class="text-white font-semibold drop-shadow-md">A partir de 120€/noite</span>
								<a href="#" class="text-white/80 hover:text-white text-sm font-medium drop-shadow-md">
									Ver disponibilidade →
								</a>
							</div>
						</div>
						
						<!-- Hotel Option 3 -->
						<div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/10 hover:bg-white/15 transition-all">
							<h4 class="text-lg font-semibold text-white mb-3 drop-shadow-md">🏠 Casa de Campo Vila Nova</h4>
							<p class="text-white/90 text-sm mb-4 drop-shadow-md">
								Alojamento local numa casa tradicional portuguesa. Ideal para grupos 
								ou famílias que prefiram mais privacidade.
							</p>
							<div class="flex items-center justify-between">
								<span class="text-white font-semibold drop-shadow-md">A partir de 60€/noite</span>
								<a href="#" class="text-white/80 hover:text-white text-sm font-medium drop-shadow-md">
									Ver disponibilidade →
								</a>
							</div>
						</div>
					</div>
					
					<div class="mt-6 bg-white/10 backdrop-blur-sm rounded-xl p-4 border border-white/10">
						<div class="flex items-start">
							<span class="text-lg mr-3">💡</span>
							<p class="text-white/90 text-sm drop-shadow-md">
								<strong>Dica:</strong> Recomendamos que reservem com antecedência, especialmente 
								para o fim de semana do casamento. Contactem-nos se precisarem de ajuda com as reservas!
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
