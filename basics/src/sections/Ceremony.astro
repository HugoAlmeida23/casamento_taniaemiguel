---
// Location section — Igreja e Quinta
---

<section id="ceremony" class="wedding-section bg-white">
	<div class="max-w-4xl mx-auto">
		<div class="section-header">
			<p class="section-subtitle">Os detalhes</p>
			<h2 class="section-title">Localização</h2>
			<div class="ornament">
				<span class="text-lg">🌿</span>
			</div>
		</div>

		<!-- Two locations: Igreja + Quinta -->
		<div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
			<!-- Igreja -->
			<div class="wedding-card text-center">
				<div class="text-3xl mb-4">⛪</div>
				<h3 class="text-xl font-light text-gray-900 mb-2" style="font-family: 'Playfair Display', serif;">
					Cerimónia
				</h3>
				<p class="text-sm text-olive-600 font-medium mb-3">Igreja Paroquial de Trofa</p>
				<p class="text-xs text-gray-500 mb-4">Cerimónia religiosa às 15:30</p>
				<a 
					href="https://www.google.com/maps/search/?api=1&query=Igreja+Paroquial+de+Santo+Tirso"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-2 px-4 py-2 bg-olive-500 hover:bg-olive-600 text-white text-xs font-medium rounded-full transition-colors"
				>
					<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
					</svg>
					Ver no mapa
				</a>
			</div>

			<!-- Quinta -->
			<div class="wedding-card text-center">
				<div class="text-3xl mb-4">🏡</div>
				<h3 class="text-xl font-light text-gray-900 mb-2" style="font-family: 'Playfair Display', serif;">
					Receção & Festa
				</h3>
				<p class="text-sm text-olive-600 font-medium mb-3">Quinta da Lage — Santo Tirso</p>
				<p class="text-xs text-gray-500 mb-4">Das 17:00 às 02:00</p>
				<a 
					href="https://www.google.com/maps/dir//''/data=!4m7!4m6!1m1!4e2!1m2!1m1!1s0xd24f5c78817c761:0x422ee52782046e16!3e0?g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAMYASAF"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-2 px-4 py-2 bg-olive-500 hover:bg-olive-600 text-white text-xs font-medium rounded-full transition-colors"
				>
					<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
					</svg>
					Ver no mapa
				</a>
			</div>
		</div>

		<!-- Quinta image -->
		<div class="mt-10 rounded-3xl overflow-hidden shadow-sm max-w-2xl mx-auto">
			<img 
				src={`${import.meta.env.BASE_URL}/images/quinta.jpg`}
				alt="Quinta da Lage - Santo Tirso" 
				class="w-full h-56 md:h-72 object-cover"
				loading="lazy"
			/>
		</div>
	</div>
</section>
