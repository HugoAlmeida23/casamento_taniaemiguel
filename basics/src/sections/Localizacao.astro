---
const locais = [
  {
    titulo: 'Cerimónia',
    nome: 'Igreja de São Roque',
    hora: '15:00',
    morada: 'Largo Trindade Coelho, 1200-470 Lisboa',
    maps: 'https://maps.google.com/?q=Igreja%20de%20S%C3%A3o%20Roque%20Lisboa',
    img: '/images/cerimonia.jpg',
  },
  {
    titulo: "Copo d'Água",
    nome: 'Palácio de Xabregas',
    hora: '18:00',
    morada: 'Rua de Xabregas 22, 1900-440 Lisboa',
    maps: 'https://maps.google.com/?q=Pal%C3%A1cio%20de%20Xabregas',
    img: '/images/rececao.jpg',
  },
];
---

<section class="bg-gray-50">
  <div class="mx-auto max-w-6xl px-6 py-20">
    <h2 class="text-3xl font-semibold text-gray-900">Localização</h2>
    <div class="mt-8 grid gap-8 md:grid-cols-2">
      {locais.map((l) => (
        <article class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
          <img src={l.img} alt={l.titulo} class="mb-4 aspect-[4/3] w-full rounded-lg object-cover" loading="lazy" />
          <h3 class="text-xl font-semibold text-gray-900">{l.titulo}</h3>
          <p class="mt-1 text-gray-700">{l.nome} — {l.hora}</p>
          <p class="text-sm text-gray-600">{l.morada}</p>
          <a href={l.maps} target="_blank" rel="noopener" class="mt-3 inline-flex text-sm font-medium text-rose-700 hover:text-rose-800">Ver no Google Maps →</a>
        </article>
      ))}
    </div>
  </div>
  <a id="dress-code"></a>
</section>
