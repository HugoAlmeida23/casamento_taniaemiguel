	// ============================================
	// RENDER STATS
	// ============================================
	function renderStats(data: typeof STATIC_CONFIRMATIONS) {
		const totalConfirmations = data.length;
		let totalAdults = data.length;
		let totalChildren = 0;

		data.forEach(row => {
			row.companions.forEach(c => {
				if (c.type === 'child') totalChildren++;
				else totalAdults++;
			});
		});

		(document.getElementById('stat-total') as HTMLElement).textContent = totalConfirmations.toString();
		(document.getElementById('stat-adults') as HTMLElement).textContent = totalAdults.toString();
		(document.getElementById('stat-children') as HTMLElement).textContent = totalChildren.toString();
		(document.getElementById('stat-total-people') as HTMLElement).textContent = (totalAdults + totalChildren).toString();
	}

	// ============================================
	// RENDER TABLE
	// ============================================
	function renderTable(data: typeof STATIC_CONFIRMATIONS) {
		const tbody = document.getElementById('confirmations-table') as HTMLTableSectionElement;
		tbody.innerHTML = '';

		if (data.length === 0) {
			tbody.innerHTML = `
				<tr>
					<td colspan="7">
						<div class="empty-state">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="17" y1="11" x2="23" y2="11"/></svg>
							<p>Nenhuma confirmação encontrada</p>
							<p class="empty-hint">Tente ajustar os termos de pesquisa</p>
						</div>
					</td>
				</tr>
			`;
			(document.getElementById('table-count') as HTMLElement).textContent = '0 resultados';
			(document.getElementById('table-people-count') as HTMLElement).textContent = '0 pessoas';
			return;
		}

		let totalPeople = 0;

		data.forEach((row, index) => {
			const tr = document.createElement('tr');
			const rowPeople = 1 + row.companions.length;
			totalPeople += rowPeople;

			// Companions
			let companionsHtml = '';
			if (row.companions.length === 0) {
				companionsHtml = '<span class="cell-none">—</span>';
			} else {
				const items = row.companions.map(c => {
					const badgeClass = c.type === 'child' ? 'badge-child' : 'badge-adult';
					const badgeLabel = c.type === 'child' ? 'Criança' : 'Adulto';
					const allergyHtml = c.allergy ? `<span class="companion-allergy">(${c.allergy})</span>` : '';
					return `
						<div class="companion-item">
							<span class="badge ${badgeClass}">${badgeLabel}</span>
							<span class="companion-name">${c.name}</span>
							${allergyHtml}
						</div>
					`;
				}).join('');
				companionsHtml = `<div class="companions-list">${items}</div>`;
			}

			// Restriction
			const restrictionHtml = row.restricoes 
				? `<span class="badge badge-restriction">${row.restricoes}</span>` 
				: '<span class="cell-none">—</span>';

			// Message
			const messageHtml = row.mensagem 
				? `<span class="cell-message" title="${row.mensagem}">${row.mensagem}</span>` 
				: '<span class="cell-none">—</span>';

			// Date
			const date = new Date(row.created_at);
			const dateStr = date.toLocaleDateString('pt-PT', { day: '2-digit', month: '2-digit', year: 'numeric' });

			tr.innerHTML = `
				<td><span class="row-num">${index + 1}</span></td>
				<td><span class="cell-name">${row.nome}</span></td>
				<td><span class="cell-phone">${row.telefone}</span></td>
				<td>${restrictionHtml}</td>
				<td>${companionsHtml}</td>
				<td>${messageHtml}</td>
				<td><span class="cell-date">${dateStr}</span></td>
			`;

			tbody.appendChild(tr);
		});

		(document.getElementById('table-count') as HTMLElement).textContent = `${data.length} confirmação${data.length !== 1 ? 'ões' : ''}`;
		(document.getElementById('table-people-count') as HTMLElement).textContent = `${totalPeople} pessoas no total`;
	}

	// ============================================
	// EXPORT CSV
	// ============================================
	exportBtn?.addEventListener('click', () => {
		exportToCSV(STATIC_CONFIRMATIONS);
		showToast('CSV exportado com sucesso', 'success');
	});

	function exportToCSV(data: typeof STATIC_CONFIRMATIONS) {
		const rows: string[][] = [];

		rows.push(['#', 'Nome', 'Telemovel', 'Restricoes', 'Acompanhante', 'Tipo', 'Alergia Acompanhante', 'Mensagem', 'Data']);

		data.forEach((row, index) => {
			const date = new Date(row.created_at).toLocaleDateString('pt-PT');

			if (row.companions.length === 0) {
				rows.push([
					(index + 1).toString(),
					row.nome,
					row.telefone,
					row.restricoes || '',
					'',
					'',
					'',
					row.mensagem || '',
					date,
				]);
			} else {
				row.companions.forEach((c, i) => {
					rows.push([
						i === 0 ? (index + 1).toString() : '',
						i === 0 ? row.nome : '',
						i === 0 ? row.telefone : '',
						i === 0 ? (row.restricoes || '') : '',
						c.name,
						c.type === 'child' ? 'Crianca' : 'Adulto',
						c.allergy || '',
						i === 0 ? (row.mensagem || '') : '',
						i === 0 ? date : '',
					]);
				});
			}
		});

		const csvContent = rows.map(row => 
			row.map(cell => `"${cell.replace(/"/g, '""')}"`).join(',')
		).join('\n');

		const blob = new Blob(['\uFEFF' + csvContent], { type: 'text/csv;charset=utf-8;' });
		const url = URL.createObjectURL(blob);
		const link = document.createElement('a');
		link.href = url;
		link.download = `confirmacoes_casamento_${new Date().toISOString().slice(0,10)}.csv`;
		link.click();
		URL.revokeObjectURL(url);
	}

	// ============================================
	// MESAS (TABLE MANAGEMENT) - CRUD
	// ============================================
	interface TableData {
		id: string;
		name: string;
		capacity: number;
	}

	interface GuestData {
		id: string;
		nome: string;
		mesa_id: string | null;
	}

	let mesasTables: TableData[] = [];
	let mesasGuests: GuestData[] = [];
	let editingTableId: string | null = null;

	const createTableForm = document.getElementById('create-table-form') as HTMLFormElement;
	const newTableName = document.getElementById('new-table-name') as HTMLInputElement;
	const newTableCapacity = document.getElementById('new-table-capacity') as HTMLInputElement;
	const mesasTableBody = document.getElementById('mesas-table-body') as HTMLTableSectionElement;
	const mesasCount = document.getElementById('mesas-count') as HTMLSpanElement;
	const mesasTotalCapacity = document.getElementById('mesas-total-capacity') as HTMLSpanElement;

	// Fetch tables and guests, then render
	async function loadMesasData() {
		try {
			const [tablesRes, guestsRes] = await Promise.all([
				fetch('/api/tables'),
				fetch('/api/guests')
			]);

			if (!tablesRes.ok) throw new Error('Erro ao carregar mesas');
			if (!guestsRes.ok) throw new Error('Erro ao carregar convidados');

			mesasTables = await tablesRes.json();
			mesasGuests = await guestsRes.json();
			renderMesasTable();
			renderGuestAssignment();
			renderSeatingGrid();
		} catch (err: any) {
			showToast(err.message || 'Erro ao carregar dados', 'error');
		}
	}

	// Calculate occupancy for a table
	function getOccupancy(tableId: string): number {
		return mesasGuests.filter(g => g.mesa_id === tableId).length;
	}

	// Render the table list
	function renderMesasTable() {
		mesasTableBody.innerHTML = '';

		if (mesasTables.length === 0) {
			mesasTableBody.innerHTML = `
				<tr>
					<td colspan="4">
						<div class="empty-state">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
							<p>Nenhuma mesa criada</p>
							<p class="empty-hint">Use o formulário acima para criar a primeira mesa</p>
						</div>
					</td>
				</tr>
			`;
			mesasCount.textContent = '0 mesas';
			if (mesasTotalCapacity) mesasTotalCapacity.textContent = '';
			return;
		}

		let totalCap = 0;
		let totalOcc = 0;

		mesasTables.forEach(table => {
			const tr = document.createElement('tr');
			const occupancy = getOccupancy(table.id);
			const isEditing = editingTableId === table.id;
			totalCap += table.capacity;
			totalOcc += occupancy;

			const pct = table.capacity > 0 ? Math.min((occupancy / table.capacity) * 100, 100) : 0;
			let fillClass = 'occupancy-fill-empty';
			if (occupancy > 0 && occupancy < table.capacity) fillClass = 'occupancy-fill-ok';
			else if (occupancy >= table.capacity && occupancy > 0) fillClass = 'occupancy-fill-full';
			if (pct > 70 && pct < 100) fillClass = 'occupancy-fill-warning';

			if (isEditing) {
				tr.innerHTML = `
					<td>
						<input type="text" class="edit-input" id="edit-name-${table.id}" value="${escapeHtml(table.name)}" />
					</td>
					<td>
						<input type="number" class="edit-input" id="edit-capacity-${table.id}" value="${table.capacity}" min="1" style="width:80px;" />
					</td>
					<td>
						<div class="occupancy-bar">
							<div class="occupancy-track"><div class="occupancy-fill ${fillClass}" style="width:${pct}%"></div></div>
							<span class="occupancy-text">${occupancy}/${table.capacity}</span>
						</div>
					</td>
					<td style="text-align:right;">
						<div style="display:flex;gap:0.5rem;justify-content:flex-end;">
							<button class="btn btn-primary btn-sm" data-action="save" data-id="${table.id}">Guardar</button>
							<button class="btn btn-secondary btn-sm" data-action="cancel-edit">Cancelar</button>
						</div>
					</td>
				`;
			} else {
				tr.innerHTML = `
					<td><span class="cell-name">${escapeHtml(table.name)}</span></td>
					<td>${table.capacity} lugares</td>
					<td>
						<div class="occupancy-bar">
							<div class="occupancy-track"><div class="occupancy-fill ${fillClass}" style="width:${pct}%"></div></div>
							<span class="occupancy-text">${occupancy}/${table.capacity}</span>
						</div>
					</td>
					<td style="text-align:right;">
						<div style="display:flex;gap:0.5rem;justify-content:flex-end;">
							<button class="btn btn-secondary btn-sm" data-action="edit" data-id="${table.id}">Editar</button>
							<button class="btn btn-danger btn-sm" data-action="delete" data-id="${table.id}" data-name="${escapeHtml(table.name)}" data-occupancy="${occupancy}">Eliminar</button>
						</div>
					</td>
				`;
			}

			mesasTableBody.appendChild(tr);
		});

		mesasCount.textContent = `${mesasTables.length} mesa${mesasTables.length !== 1 ? 's' : ''}`;
		if (mesasTotalCapacity) mesasTotalCapacity.textContent = `${totalOcc}/${totalCap} lugares ocupados`;
	}

	// Render the seating overview grid
	function renderSeatingGrid() {
		const gridContainer = document.getElementById('seating-grid') as HTMLDivElement;
		const unassignedBadge = document.getElementById('seating-grid-unassigned') as HTMLSpanElement;
		const unassignedCountEl = document.getElementById('seating-grid-unassigned-count') as HTMLSpanElement;

		if (!gridContainer) return;

		const unassignedCount = mesasGuests.filter(g => !g.mesa_id).length;

		if (unassignedCount > 0) {
			unassignedBadge.style.display = 'inline-flex';
			unassignedCountEl.textContent = unassignedCount.toString();
		} else {
			unassignedBadge.style.display = 'none';
		}

		if (mesasTables.length === 0) {
			gridContainer.innerHTML = `
				<div class="empty-state" style="grid-column:1/-1;padding:2rem;">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
					<p>Nenhuma mesa criada ainda</p>
				</div>
			`;
			return;
		}

		let html = '';
		mesasTables.forEach(table => {
			const occupancy = getOccupancy(table.id);
			const assignedGuests = mesasGuests.filter(g => g.mesa_id === table.id);

			let fillLevel: 'empty' | 'partial' | 'full';
			if (occupancy === 0) fillLevel = 'empty';
			else if (occupancy >= table.capacity) fillLevel = 'full';
			else fillLevel = 'partial';

			const cardClass = `seating-card seating-card-${fillLevel}`;
			const countClass = `seating-card-count seating-count-${fillLevel}`;

			let guestsHtml = '';
			if (assignedGuests.length === 0) {
				guestsHtml = `<p class="seating-card-empty-msg">Sem convidados atribuídos</p>`;
			} else {
				guestsHtml = '<ul class="seating-card-guests">';
				assignedGuests.forEach(guest => {
					guestsHtml += `<li>${escapeHtml(guest.nome)}</li>`;
				});
				guestsHtml += '</ul>';
			}

			html += `
				<div class="${cardClass}">
					<div class="seating-card-top">
						<span class="seating-card-name">${escapeHtml(table.name)}</span>
						<span class="${countClass}">${occupancy}/${table.capacity}</span>
					</div>
					${guestsHtml}
				</div>
			`;
		});

		gridContainer.innerHTML = html;
	}

	// Escape HTML to prevent XSS
	function escapeHtml(text: string): string {
		const div = document.createElement('div');
		div.textContent = text;
		return div.innerHTML;
	}

	// Create table
	createTableForm?.addEventListener('submit', async (e) => {
		e.preventDefault();

		const name = newTableName.value.trim();
		const capacity = parseInt(newTableCapacity.value, 10);

		if (!name) {
			showToast('O nome da mesa é obrigatório', 'warning');
			return;
		}
		if (!capacity || capacity < 1) {
			showToast('A capacidade deve ser pelo menos 1', 'warning');
			return;
		}

		try {
			const res = await fetch('/api/tables', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ name, capacity })
			});

			if (!res.ok) {
				const data = await res.json();
				throw new Error(data.error || 'Erro ao criar mesa');
			}

			const newTable: TableData = await res.json();
			mesasTables.push(newTable);
			renderMesasTable();
			renderSeatingGrid();

			newTableName.value = '';
			newTableCapacity.value = '';
			showToast(`Mesa "${name}" criada com sucesso`, 'success');
		} catch (err: any) {
			showToast(err.message || 'Erro ao criar mesa', 'error');
		}
	});

	// Handle table actions (edit, delete, save, cancel)
	mesasTableBody?.addEventListener('click', async (e) => {
		const target = e.target as HTMLElement;
		const button = target.closest('button') as HTMLButtonElement | null;
		if (!button) return;

		const action = button.getAttribute('data-action');
		const id = button.getAttribute('data-id');

		if (action === 'edit' && id) {
			editingTableId = id;
			renderMesasTable();
		}

		if (action === 'cancel-edit') {
			editingTableId = null;
			renderMesasTable();
		}

		if (action === 'save' && id) {
			const nameInput = document.getElementById(`edit-name-${id}`) as HTMLInputElement;
			const capacityInput = document.getElementById(`edit-capacity-${id}`) as HTMLInputElement;

			const newName = nameInput.value.trim();
			const newCapacity = parseInt(capacityInput.value, 10);

			if (!newName) {
				showToast('O nome da mesa é obrigatório', 'warning');
				return;
			}
			if (!newCapacity || newCapacity < 1) {
				showToast('A capacidade deve ser pelo menos 1', 'warning');
				return;
			}

			try {
				const res = await fetch(`/api/tables/${id}`, {
					method: 'PATCH',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ name: newName, capacity: newCapacity })
				});

				if (!res.ok) {
					const data = await res.json();
					throw new Error(data.error || 'Erro ao atualizar mesa');
				}

				const tableIndex = mesasTables.findIndex(t => t.id === id);
				if (tableIndex !== -1) {
					mesasTables[tableIndex].name = newName;
					mesasTables[tableIndex].capacity = newCapacity;
				}

				editingTableId = null;
				renderMesasTable();
				renderSeatingGrid();
				renderGuestAssignment();
				showToast(`Mesa "${newName}" atualizada`, 'success');
			} catch (err: any) {
				showToast(err.message || 'Erro ao atualizar mesa', 'error');
			}
		}

		if (action === 'delete' && id) {
			const tableName = button.getAttribute('data-name') || 'esta mesa';
			const occupancy = parseInt(button.getAttribute('data-occupancy') || '0', 10);
			showDeleteConfirmation(id, tableName, occupancy);
		}
	});

	// Show delete confirmation dialog
	function showDeleteConfirmation(tableId: string, tableName: string, occupancy: number) {
		const overlay = document.createElement('div');
		overlay.className = 'confirm-overlay';

		const occupancyWarning = occupancy > 0
			? `<p style="margin-top:-0.5rem;">⚠️ Esta mesa tem <strong>${occupancy}</strong> convidado${occupancy !== 1 ? 's' : ''} atribuído${occupancy !== 1 ? 's' : ''}. Ao eliminar, ficarão sem mesa.</p>`
			: '';

		overlay.innerHTML = `
			<div class="confirm-dialog">
				<h3>Eliminar Mesa</h3>
				<p>Tem a certeza que deseja eliminar a mesa "<strong>${escapeHtml(tableName)}</strong>"?</p>
				${occupancyWarning}
				<div class="confirm-actions">
					<button class="btn btn-secondary" id="confirm-cancel">Cancelar</button>
					<button class="btn btn-danger" id="confirm-delete">Eliminar</button>
				</div>
			</div>
		`;

		document.body.appendChild(overlay);

		const cancelBtn = document.getElementById('confirm-cancel') as HTMLButtonElement;
		const deleteBtn = document.getElementById('confirm-delete') as HTMLButtonElement;

		cancelBtn.addEventListener('click', () => overlay.remove());
		overlay.addEventListener('click', (e) => {
			if (e.target === overlay) overlay.remove();
		});

		deleteBtn.addEventListener('click', async () => {
			try {
				const res = await fetch(`/api/tables/${tableId}`, { method: 'DELETE' });

				if (!res.ok) {
					const data = await res.json();
					throw new Error(data.error || 'Erro ao eliminar mesa');
				}

				mesasTables = mesasTables.filter(t => t.id !== tableId);
				mesasGuests = mesasGuests.map(g => g.mesa_id === tableId ? { ...g, mesa_id: null } : g);
				renderMesasTable();
				renderSeatingGrid();
				renderGuestAssignment();
				overlay.remove();
				showToast(`Mesa "${tableName}" eliminada`, 'success');
			} catch (err: any) {
				showToast(err.message || 'Erro ao eliminar mesa', 'error');
				overlay.remove();
			}
		});
	}

	// Load mesas data when the Mesas tab is activated
	const mesasTabBtn = document.getElementById('tab-mesas') as HTMLButtonElement;
	let mesasLoaded = false;

	mesasTabBtn?.addEventListener('click', () => {
		if (!mesasLoaded) {
			mesasLoaded = true;
			loadMesasData();
		}
	});

	// ============================================
	// GUEST ASSIGNMENT
	// ============================================
	const guestAssignBody = document.getElementById('guest-assign-body') as HTMLTableSectionElement;
	const guestAssignCount = document.getElementById('guest-assign-count') as HTMLSpanElement;
	const guestAssignUnassigned = document.getElementById('guest-assign-unassigned') as HTMLSpanElement;
	const guestAssignSearch = document.getElementById('guest-assign-search') as HTMLInputElement;

	let guestAssignFilter = '';

	guestAssignSearch?.addEventListener('input', () => {
		guestAssignFilter = guestAssignSearch.value.toLowerCase().trim();
		renderGuestAssignment();
	});

	function renderGuestAssignment() {
		if (!guestAssignBody) return;
		guestAssignBody.innerHTML = '';

		let filteredGuests = mesasGuests;
		if (guestAssignFilter) {
			filteredGuests = mesasGuests.filter(g => g.nome.toLowerCase().includes(guestAssignFilter));
		}

		const unassignedCount = mesasGuests.filter(g => !g.mesa_id).length;

		if (filteredGuests.length === 0) {
			guestAssignBody.innerHTML = `
				<tr>
					<td colspan="4">
						<div class="empty-state">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
							<p>${guestAssignFilter ? 'Nenhum convidado encontrado' : 'Nenhum convidado registado'}</p>
						</div>
					</td>
				</tr>
			`;
			guestAssignCount.textContent = `${mesasGuests.length} convidado${mesasGuests.length !== 1 ? 's' : ''}`;
			guestAssignUnassigned.textContent = `${unassignedCount} sem mesa`;
			return;
		}

		filteredGuests.forEach((guest, index) => {
			const tr = document.createElement('tr');
			const currentTable = mesasTables.find(t => t.id === guest.mesa_id);
			const isAtCapacity = currentTable ? getOccupancy(currentTable.id) >= currentTable.capacity : false;

			if (isAtCapacity && guest.mesa_id) {
				tr.className = 'guest-row-warning';
			}

			let optionsHtml = '<option value="">Sem mesa</option>';
			mesasTables.forEach(table => {
				const occ = getOccupancy(table.id);
				const atCapacity = occ >= table.capacity;
				const selected = guest.mesa_id === table.id ? 'selected' : '';
				const capacityLabel = atCapacity ? ' ⚠️' : '';
				optionsHtml += `<option value="${table.id}" ${selected}>${escapeHtml(table.name)} (${occ}/${table.capacity})${capacityLabel}</option>`;
			});

			let statusHtml = '';
			if (!guest.mesa_id) {
				statusHtml = '<span class="status-badge status-unassigned">Sem mesa</span>';
			} else if (isAtCapacity) {
				statusHtml = '<span class="status-badge status-full">Mesa lotada</span>';
			} else {
				statusHtml = '<span class="status-badge status-assigned">Atribuído</span>';
			}

			tr.innerHTML = `
				<td><span class="row-num">${index + 1}</span></td>
				<td><span class="cell-name">${escapeHtml(guest.nome)}</span></td>
				<td>
					<select class="guest-assign-select" data-guest-id="${guest.id}">
						${optionsHtml}
					</select>
				</td>
				<td>${statusHtml}</td>
			`;

			guestAssignBody.appendChild(tr);
		});

		guestAssignCount.textContent = `${mesasGuests.length} convidado${mesasGuests.length !== 1 ? 's' : ''}`;
		guestAssignUnassigned.textContent = `${unassignedCount} sem mesa`;
	}

	// Handle guest assignment changes
	guestAssignBody?.addEventListener('change', async (e) => {
		const target = e.target as HTMLSelectElement;
		if (!target.classList.contains('guest-assign-select')) return;

		const guestId = target.getAttribute('data-guest-id');
		if (!guestId) return;

		const newTableId = target.value || null;

		try {
			const res = await fetch(`/api/guests/${guestId}/assign`, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ table_id: newTableId })
			});

			if (!res.ok) {
				const data = await res.json();
				throw new Error(data.error || 'Erro ao atribuir mesa');
			}

			const guestIndex = mesasGuests.findIndex(g => g.id === guestId);
			if (guestIndex !== -1) {
				mesasGuests[guestIndex].mesa_id = newTableId;
			}

			renderMesasTable();
			renderGuestAssignment();
			renderSeatingGrid();
			showToast('Mesa atribuída com sucesso', 'success');
		} catch (err: any) {
			showToast(err.message || 'Erro ao atribuir mesa', 'error');
			const guest = mesasGuests.find(g => g.id === guestId);
			if (guest) {
				target.value = guest.mesa_id || '';
			}
		}
	});
</script>

</body>
</html>
