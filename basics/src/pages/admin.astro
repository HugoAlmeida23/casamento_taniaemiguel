---
// Admin Dashboard — Tânia & Miguel Wedding
---

<html lang="pt">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Admin — Tânia & Miguel</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Login Screen -->
  <div id="login-screen" class="login-screen">
    <div class="login-card">
      <div class="login-heart">&#10084;</div>
      <h1 class="login-title">Tânia & Miguel</h1>
      <p class="login-subtitle">Painel de Administração</p>
      <form id="login-form">
        <div class="form-group">
          <label for="username">Utilizador</label>
          <input type="text" id="username" placeholder="Utilizador" autocomplete="username" />
        </div>
        <div class="form-group">
          <label for="password">Palavra-passe</label>
          <input type="password" id="password" placeholder="Palavra-passe" autocomplete="current-password" />
        </div>
        <p id="login-error" class="login-error"></p>
        <button type="submit" class="btn btn-primary btn-full">Entrar</button>
      </form>
    </div>
  </div>

  <!-- Dashboard -->
  <div id="dashboard" class="dashboard hidden">
    <!-- Header -->
    <header class="dash-header">
      <div class="dash-header-inner">
        <h1 class="dash-logo">T&M <span>Admin</span></h1>
        <button id="logout-btn" class="btn btn-outline btn-sm">Sair</button>
      </div>
    </header>

    <!-- Tabs -->
    <nav class="tabs-nav">
      <button class="tab-btn active" data-tab="confirmacoes">Confirmações</button>
      <button class="tab-btn" data-tab="mesas">Mesas</button>
      <button class="tab-btn" data-tab="fotos">Fotos</button>
    </nav>

    <!-- Tab: Confirmações -->
    <section id="tab-confirmacoes" class="tab-content active">
      <div class="stats-grid">
        <div class="stat-card stat-card--olive">
          <div class="stat-label">Total Confirmações</div>
          <div class="stat-value" id="stat-confirmacoes">0</div>
        </div>
        <div class="stat-card stat-card--gold">
          <div class="stat-label">Total Pessoas</div>
          <div class="stat-value" id="stat-pessoas">0</div>
        </div>
        <div class="stat-card stat-card--green">
          <div class="stat-label">Adultos</div>
          <div class="stat-value" id="stat-adultos">0</div>
        </div>
        <div class="stat-card stat-card--rose">
          <div class="stat-label">Crianças</div>
          <div class="stat-value" id="stat-criancas">0</div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <input type="text" id="search-input" class="search-input" placeholder="Pesquisar por nome, telemóvel..." />
          <button id="export-csv-btn" class="btn btn-primary btn-sm">Exportar CSV</button>
        </div>
        <div class="table-wrapper">
          <table class="data-table">
            <thead>
              <tr>
                <th>Nome</th>
                <th>Telemóvel</th>
                <th>Restrições</th>
                <th>Acompanhantes</th>
                <th>Mensagem</th>
                <th>Data</th>
              </tr>
            </thead>
            <tbody id="confirmacoes-tbody"></tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Tab: Mesas -->
    <section id="tab-mesas" class="tab-content">
      <div class="mesas-layout">
        <div class="card">
          <h3 class="card-title">Criar Nova Mesa</h3>
          <form id="create-table-form" class="form-inline">
            <div class="form-group">
              <label for="table-name">Nome</label>
              <input type="text" id="table-name" placeholder="Ex: Mesa 1" required />
            </div>
            <div class="form-group">
              <label for="table-capacity">Capacidade</label>
              <input type="number" id="table-capacity" placeholder="8" min="1" required />
            </div>
            <button type="submit" class="btn btn-primary">Criar Mesa</button>
          </form>
        </div>

        <div class="card">
          <h3 class="card-title">Lista de Mesas</h3>
          <div class="table-wrapper">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Nome</th>
                  <th>Capacidade</th>
                  <th>Ocupação</th>
                  <th>Ações</th>
                </tr>
              </thead>
              <tbody id="mesas-tbody"></tbody>
            </table>
          </div>
        </div>

        <div class="card">
          <h3 class="card-title">Atribuir Convidados</h3>
          <div class="assign-form">
            <div class="form-group">
              <label for="assign-guest">Convidado</label>
              <select id="assign-guest"><option value="">Selecionar convidado...</option></select>
            </div>
            <div class="form-group">
              <label for="assign-table">Mesa</label>
              <select id="assign-table"><option value="">Selecionar mesa...</option></select>
            </div>
            <button id="assign-btn" class="btn btn-primary">Atribuir</button>
          </div>
        </div>

        <div class="card">
          <h3 class="card-title">Visão Geral</h3>
          <div id="mesas-grid" class="mesas-grid"></div>
        </div>
      </div>
    </section>

    <!-- Tab: Fotos -->
    <section id="tab-fotos" class="tab-content">
      <div class="card">
        <h3 class="card-title">Galeria de Fotos</h3>
        <div id="fotos-grid" class="fotos-grid"></div>
        <p id="fotos-empty" class="empty-state hidden">Nenhuma foto encontrada.</p>
      </div>
    </section>
  </div>
<script>
  import { supabase } from '../scripts/supabase';

  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const ADMIN_USER = 'admin';
  const ADMIN_PASS = 'admin';

  // DOM Elements
  const loginScreen = document.getElementById('login-screen') as HTMLDivElement;
  const dashboard = document.getElementById('dashboard') as HTMLDivElement;
  const loginForm = document.getElementById('login-form') as HTMLFormElement;
  const loginError = document.getElementById('login-error') as HTMLParagraphElement;
  const logoutBtn = document.getElementById('logout-btn') as HTMLButtonElement;

  // Check session
  function checkSession() {
    if (sessionStorage.getItem('admin_logged_in') === 'true') {
      showDashboard();
    }
  }

  function showDashboard() {
    loginScreen.classList.add('hidden');
    dashboard.classList.remove('hidden');
    loadConfirmacoes();
    loadMesas();
    loadFotos();
  }

  // Login
  loginForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const user = (document.getElementById('username') as HTMLInputElement).value.trim();
    const pass = (document.getElementById('password') as HTMLInputElement).value;

    if (user === ADMIN_USER && pass === ADMIN_PASS) {
      sessionStorage.setItem('admin_logged_in', 'true');
      loginError.textContent = '';
      showDashboard();
    } else {
      loginError.textContent = 'Credenciais inválidas.';
    }
  });

  // Logout
  logoutBtn.addEventListener('click', () => {
    sessionStorage.removeItem('admin_logged_in');
    dashboard.classList.add('hidden');
    loginScreen.classList.remove('hidden');
  });

  // Tabs
  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabContents = document.querySelectorAll('.tab-content');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab!;
      tabBtns.forEach(b => b.classList.remove('active'));
      tabContents.forEach(c => c.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById(`tab-${tab}`)!.classList.add('active');
    });
  });

  // ==================== CONFIRMAÇÕES ====================
  interface GuestRecord {
    id: string;
    nome: string;
    telefone?: string;
    restricoes?: string;
    companions?: any[];
    mensagem?: string;
    created_at: string;
    mesa_id?: string | null;
    acompanha?: number;
    checked_in?: number;
  }

  let allRsvps: GuestRecord[] = [];

  async function loadConfirmacoes() {
    const { data, error } = await supabase
      .from('guests')
      .select('*')
      .order('created_at', { ascending: false });

    if (error) {
      console.error('Error loading guests:', error);
      return;
    }

    allRsvps = data || [];
    updateStats();
    renderConfirmacoes(allRsvps);
  }

  function updateStats() {
    const total = allRsvps.length;
    let totalPessoas = 0;
    let totalAdultos = 0;
    let totalCriancas = 0;

    allRsvps.forEach(r => {
      const companions = r.companions || [];
      const adults = 1 + companions.filter((c: any) => c.type === 'adult').length;
      const children = companions.filter((c: any) => c.type === 'child').length;
      totalAdultos += adults;
      totalCriancas += children;
      totalPessoas += adults + children;
    });

    document.getElementById('stat-confirmacoes')!.textContent = String(total);
    document.getElementById('stat-pessoas')!.textContent = String(totalPessoas);
    document.getElementById('stat-adultos')!.textContent = String(totalAdultos);
    document.getElementById('stat-criancas')!.textContent = String(totalCriancas);
  }

  function renderConfirmacoes(rsvps: GuestRecord[]) {
    const tbody = document.getElementById('confirmacoes-tbody')!;
    tbody.innerHTML = rsvps.map(r => {
      const companions = r.companions || [];
      const companionCount = companions.length;
      const companionNames = companions.map((c: any) => c.name || c).join(', ');
      const date = new Date(r.created_at).toLocaleDateString('pt-PT', {
        day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit'
      });

      return `<tr>
        <td><strong>${escapeHtml(r.nome)}</strong></td>
        <td>${escapeHtml(r.telefone || '—')}</td>
        <td>${escapeHtml(r.restricoes || '—')}</td>
        <td>${companionCount > 0 ? `${companionCount} — ${escapeHtml(companionNames)}` : '—'}</td>
        <td>${escapeHtml(r.mensagem || '—')}</td>
        <td style="white-space:nowrap">${date}</td>
      </tr>`;
    }).join('');
  }

  // Search
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  searchInput.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase();
    const filtered = allRsvps.filter(r =>
      r.nome.toLowerCase().includes(q) ||
      (r.telefone || '').toLowerCase().includes(q) ||
      (r.mensagem || '').toLowerCase().includes(q)
    );
    renderConfirmacoes(filtered);
  });

  // Export CSV
  document.getElementById('export-csv-btn')!.addEventListener('click', () => {
    const headers = ['Nome', 'Telemóvel', 'Restrições', 'Acompanhantes', 'Mensagem', 'Data'];
    const rows = allRsvps.map(r => {
      const companions = (r.companions || []).map((c: any) => c.name || c).join('; ');
      const date = new Date(r.created_at).toLocaleDateString('pt-PT');
      return [r.nome, r.telefone || '', r.restricoes || '', companions, r.mensagem || '', date];
    });

    const csv = [headers, ...rows].map(row => row.map(cell => `"${String(cell).replace(/"/g, '""')}"`).join(',')).join('\n');
    const blob = new Blob(['\ufeff' + csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `confirmacoes_${new Date().toISOString().slice(0,10)}.csv`;
    a.click();
    URL.revokeObjectURL(url);
  });

  // ==================== MESAS ====================
  interface Mesa {
    id: string;
    name: string;
    capacity: number;
    guests?: string[];
  }

  let allMesas: Mesa[] = [];
  let allGuestsList: { id: string; nome: string; mesa_id?: string | null }[] = [];

  async function loadMesas() {
    const [mesasRes, guestsRes] = await Promise.all([
      supabase.from('tables').select('*').order('name'),
      supabase.from('guests').select('id, nome, mesa_id')
    ]);

    allMesas = mesasRes.data || [];
    allGuestsList = guestsRes.data || [];

    renderMesasTable();
    renderMesasGrid();
    populateDropdowns();
  }

  function renderMesasTable() {
    const tbody = document.getElementById('mesas-tbody')!;
    tbody.innerHTML = allMesas.map(m => {
      const assigned = allGuestsList.filter(g => g.mesa_id === m.id);
      const occupancy = assigned.length;
      const pct = m.capacity > 0 ? Math.round((occupancy / m.capacity) * 100) : 0;

      return `<tr>
        <td><strong>${escapeHtml(m.name)}</strong></td>
        <td>${m.capacity}</td>
        <td>${occupancy}/${m.capacity} (${pct}%)</td>
        <td class="action-btns">
          <button class="btn btn-danger btn-icon" onclick="deleteMesa('${m.id}')" title="Eliminar">✕</button>
        </td>
      </tr>`;
    }).join('');
  }

  function renderMesasGrid() {
    const grid = document.getElementById('mesas-grid')!;
    grid.innerHTML = allMesas.map(m => {
      const assigned = allGuestsList.filter(g => g.mesa_id === m.id);
      const pct = m.capacity > 0 ? Math.round((assigned.length / m.capacity) * 100) : 0;
      const guestList = assigned.map(g =>
        `<div class="mesa-guest-row">
          <span>${escapeHtml(g.nome)}</span>
          <button class="btn-unassign" onclick="unassignGuest('${g.id}')" title="Remover da mesa">✕</button>
        </div>`
      ).join('');

      return `<div class="mesa-card">
        <div class="mesa-card-name">${escapeHtml(m.name)}</div>
        <div class="mesa-card-info">${assigned.length} / ${m.capacity} lugares</div>
        <div class="mesa-card-bar"><div class="mesa-card-bar-fill" style="width:${pct}%"></div></div>
        <div class="mesa-card-guests">${guestList || '<em style="color:var(--gray-400)">Sem convidados</em>'}</div>
      </div>`;
    }).join('');
  }

  (window as any).unassignGuest = async (guestId: string) => {
    const { error } = await supabase.from('guests').update({ mesa_id: null }).eq('id', guestId);
    if (error) {
      alert('Erro ao remover da mesa: ' + error.message);
      return;
    }
    await loadMesas();
  };

  function populateDropdowns() {
    const guestSelect = document.getElementById('assign-guest') as HTMLSelectElement;
    const tableSelect = document.getElementById('assign-table') as HTMLSelectElement;

    const unassigned = allGuestsList.filter(g => !g.mesa_id);
    guestSelect.innerHTML = '<option value="">Selecionar convidado...</option>' +
      unassigned.map(g => `<option value="${g.id}">${escapeHtml(g.nome)}</option>`).join('');

    tableSelect.innerHTML = '<option value="">Selecionar mesa...</option>' +
      allMesas.map(m => {
        const count = allGuestsList.filter(g => g.mesa_id === m.id).length;
        return `<option value="${m.id}">${escapeHtml(m.name)} (${count}/${m.capacity})</option>`;
      }).join('');
  }

  // Create table
  document.getElementById('create-table-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const nameInput = document.getElementById('table-name') as HTMLInputElement;
    const capInput = document.getElementById('table-capacity') as HTMLInputElement;

    const name = nameInput.value.trim();
    const capacity = parseInt(capInput.value);

    if (!name || !capacity) return;

    const { error } = await supabase.from('tables').insert({ name, capacity });
    if (error) {
      alert('Erro ao criar mesa: ' + error.message);
      return;
    }

    nameInput.value = '';
    capInput.value = '';
    await loadMesas();
  });

  // Delete table
  (window as any).deleteMesa = async (id: string) => {
    if (!confirm('Tem certeza que deseja eliminar esta mesa?')) return;

    // Unassign guests first
    await supabase.from('guests').update({ mesa_id: null }).eq('mesa_id', id);
    const { error } = await supabase.from('tables').delete().eq('id', id);
    if (error) {
      alert('Erro ao eliminar mesa: ' + error.message);
      return;
    }
    await loadMesas();
  };

  // Assign guest
  document.getElementById('assign-btn')!.addEventListener('click', async () => {
    const guestId = (document.getElementById('assign-guest') as HTMLSelectElement).value;
    const tableId = (document.getElementById('assign-table') as HTMLSelectElement).value;

    if (!guestId || !tableId) {
      alert('Selecione um convidado e uma mesa.');
      return;
    }

    const { error } = await supabase.from('guests').update({ mesa_id: tableId }).eq('id', guestId);
    if (error) {
      alert('Erro ao atribuir: ' + error.message);
      return;
    }
    await loadMesas();
  });

  // ==================== FOTOS ====================
  async function loadFotos() {
    const { data, error } = await supabase
      .from('photos')
      .select('*')
      .order('created_at', { ascending: false });

    const grid = document.getElementById('fotos-grid')!;
    const empty = document.getElementById('fotos-empty')!;

    if (error || !data || data.length === 0) {
      grid.innerHTML = '';
      empty.classList.remove('hidden');
      return;
    }

    empty.classList.add('hidden');
    grid.innerHTML = data.map(photo => {
      const thumbUrl = `${SUPABASE_URL}/storage/v1/render/image/public/wedding-photos/${photo.storage_path}?width=400`;
      const date = new Date(photo.created_at).toLocaleDateString('pt-PT', {
        day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit'
      });

      return `<div class="foto-card">
        <img src="${thumbUrl}" alt="Foto de ${escapeHtml(photo.uploader_name || 'Anónimo')}" loading="lazy" />
        <div class="foto-card-info">
          <div class="foto-card-meta">
            <strong>${escapeHtml(photo.uploader_name || 'Anónimo')}</strong>
            ${date}
          </div>
          <button class="btn btn-danger btn-icon" onclick="deletePhoto('${photo.id}', '${photo.storage_path}')" title="Eliminar">✕</button>
        </div>
      </div>`;
    }).join('');
  }

  (window as any).deletePhoto = async (id: string, path: string) => {
    if (!confirm('Tem certeza que deseja eliminar esta foto?')) return;

    await supabase.storage.from('wedding-photos').remove([path]);
    const { error } = await supabase.from('photos').delete().eq('id', id);
    if (error) {
      alert('Erro ao eliminar foto: ' + error.message);
      return;
    }
    await loadFotos();
  };

  // ==================== UTILS ====================
  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // Init
  checkSession();
</script>

<style>
  :root {
    --olive: #5c6e44;
    --olive-light: #7a9157;
    --gold: #d4983a;
    --gold-light: #e8b86d;
    --beige: #faf7f0;
    --beige-dark: #f0ebe0;
    --white: #ffffff;
    --gray-50: #f9fafb;
    --gray-100: #f3f4f6;
    --gray-200: #e5e7eb;
    --gray-300: #d1d5db;
    --gray-400: #9ca3af;
    --gray-500: #6b7280;
    --gray-600: #4b5563;
    --gray-700: #374151;
    --gray-800: #1f2937;
    --gray-900: #111827;
    --rose: #e8a0bf;
    --green: #6db070;
    --red: #ef4444;
    --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
    --shadow: 0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -2px rgba(0,0,0,0.05);
    --shadow-md: 0 10px 15px -3px rgba(0,0,0,0.08), 0 4px 6px -4px rgba(0,0,0,0.04);
    --shadow-lg: 0 20px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.05);
    --radius: 16px;
    --radius-sm: 10px;
    --radius-full: 9999px;
    --transition: all 0.2s ease;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--beige);
    color: var(--gray-800);
    line-height: 1.6;
    min-height: 100vh;
  }

  h1, h2, h3 { font-family: 'Playfair Display', serif; }

  .hidden { display: none !important; }

  /* Login Screen */
  .login-screen {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--olive) 0%, #3d4a2e 100%);
    padding: 1rem;
  }

  .login-card {
    background: var(--white);
    border-radius: var(--radius);
    padding: 3rem 2.5rem;
    width: 100%;
    max-width: 400px;
    box-shadow: var(--shadow-lg);
    text-align: center;
    animation: fadeInUp 0.6s ease;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .login-heart {
    font-size: 3rem;
    color: var(--gold);
    margin-bottom: 0.5rem;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
  }

  .login-title {
    font-size: 1.75rem;
    color: var(--olive);
    margin-bottom: 0.25rem;
  }

  .login-subtitle {
    color: var(--gray-500);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }

  .form-group {
    margin-bottom: 1rem;
    text-align: left;
  }

  .form-group label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--gray-600);
    margin-bottom: 0.35rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .form-group input,
  .form-group select {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--gray-200);
    border-radius: var(--radius-sm);
    font-size: 0.95rem;
    font-family: inherit;
    transition: var(--transition);
    background: var(--gray-50);
  }

  .form-group input:focus,
  .form-group select:focus {
    outline: none;
    border-color: var(--olive);
    box-shadow: 0 0 0 3px rgba(92, 110, 68, 0.1);
    background: var(--white);
  }

  .login-error {
    color: var(--red);
    font-size: 0.85rem;
    min-height: 1.25rem;
    margin-bottom: 0.5rem;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    border: none;
    border-radius: var(--radius-full);
    font-size: 0.9rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: var(--transition);
    text-decoration: none;
  }

  .btn-primary {
    background: var(--olive);
    color: var(--white);
  }

  .btn-primary:hover {
    background: var(--olive-light);
    transform: translateY(-1px);
    box-shadow: var(--shadow);
  }

  .btn-outline {
    background: transparent;
    color: var(--olive);
    border: 1.5px solid var(--olive);
  }

  .btn-outline:hover {
    background: var(--olive);
    color: var(--white);
  }

  .btn-danger {
    background: var(--red);
    color: var(--white);
  }

  .btn-danger:hover {
    background: #dc2626;
    transform: translateY(-1px);
  }

  .btn-sm {
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
  }

  .btn-full { width: 100%; }

  .btn-icon {
    width: 32px;
    height: 32px;
    padding: 0;
    border-radius: 50%;
    font-size: 0.85rem;
  }

  /* Dashboard Header */
  .dash-header {
    background: var(--white);
    border-bottom: 1px solid var(--gray-200);
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: var(--shadow-sm);
  }

  .dash-header-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .dash-logo {
    font-size: 1.4rem;
    color: var(--olive);
  }

  .dash-logo span {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    color: var(--gray-400);
    margin-left: 0.5rem;
  }

  /* Tabs */
  .tabs-nav {
    max-width: 1400px;
    margin: 1.5rem auto 0;
    padding: 0 2rem;
    display: flex;
    gap: 0.5rem;
  }

  .tab-btn {
    padding: 0.7rem 1.5rem;
    border: none;
    background: var(--white);
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--gray-500);
    cursor: pointer;
    transition: var(--transition);
    border-bottom: 3px solid transparent;
  }

  .tab-btn:hover {
    color: var(--olive);
    background: var(--white);
  }

  .tab-btn.active {
    color: var(--olive);
    border-bottom-color: var(--gold);
    font-weight: 600;
  }

  /* Tab Content */
  .tab-content {
    display: none;
    max-width: 1400px;
    margin: 0 auto;
    padding: 1.5rem 2rem 3rem;
    animation: fadeIn 0.3s ease;
  }

  .tab-content.active { display: block; }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* Stats Grid */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .stat-card {
    background: var(--white);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    box-shadow: var(--shadow);
    border-left: 4px solid var(--gray-300);
    transition: var(--transition);
  }

  .stat-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .stat-card--olive { border-left-color: var(--olive); }
  .stat-card--gold { border-left-color: var(--gold); }
  .stat-card--green { border-left-color: var(--green); }
  .stat-card--rose { border-left-color: var(--rose); }

  .stat-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--gray-500);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.25rem;
  }

  .stat-value {
    font-size: 2rem;
    font-weight: 700;
    color: var(--gray-800);
    font-family: 'Playfair Display', serif;
  }

  /* Cards */
  .card {
    background: var(--white);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow);
    margin-bottom: 1.5rem;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .card-title {
    font-size: 1.1rem;
    color: var(--olive);
    margin-bottom: 1rem;
  }

  /* Search */
  .search-input {
    flex: 1;
    min-width: 200px;
    padding: 0.6rem 1rem;
    border: 1.5px solid var(--gray-200);
    border-radius: var(--radius-full);
    font-size: 0.9rem;
    font-family: inherit;
    transition: var(--transition);
    background: var(--gray-50);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--olive);
    box-shadow: 0 0 0 3px rgba(92, 110, 68, 0.1);
    background: var(--white);
  }

  /* Tables */
  .table-wrapper {
    overflow-x: auto;
    border-radius: var(--radius-sm);
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .data-table thead {
    background: var(--olive);
    color: var(--white);
  }

  .data-table th {
    padding: 0.85rem 1rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  .data-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--gray-100);
    vertical-align: top;
  }

  .data-table tbody tr {
    transition: var(--transition);
  }

  .data-table tbody tr:nth-child(even) {
    background: var(--gray-50);
  }

  .data-table tbody tr:hover {
    background: rgba(92, 110, 68, 0.05);
  }

  /* Mesas */
  .mesas-layout {
    display: grid;
    gap: 1.5rem;
  }

  .form-inline {
    display: flex;
    gap: 1rem;
    align-items: flex-end;
    flex-wrap: wrap;
  }

  .form-inline .form-group {
    margin-bottom: 0;
    flex: 1;
    min-width: 150px;
  }

  .assign-form {
    display: flex;
    gap: 1rem;
    align-items: flex-end;
    flex-wrap: wrap;
  }

  .assign-form .form-group {
    flex: 1;
    min-width: 180px;
    margin-bottom: 0;
  }

  .mesas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .mesa-card {
    background: var(--beige);
    border: 1.5px solid var(--gray-200);
    border-radius: var(--radius-sm);
    padding: 1.25rem;
    transition: var(--transition);
  }

  .mesa-card:hover {
    border-color: var(--olive);
    box-shadow: var(--shadow);
  }

  .mesa-card-name {
    font-weight: 700;
    color: var(--olive);
    margin-bottom: 0.25rem;
    font-family: 'Playfair Display', serif;
  }

  .mesa-card-info {
    font-size: 0.8rem;
    color: var(--gray-500);
    margin-bottom: 0.5rem;
  }

  .mesa-card-bar {
    height: 6px;
    background: var(--gray-200);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }

  .mesa-card-bar-fill {
    height: 100%;
    background: var(--olive);
    border-radius: 3px;
    transition: width 0.4s ease;
  }

  .mesa-card-guests {
    font-size: 0.78rem;
    color: var(--gray-600);
    line-height: 1.5;
  }

  .mesa-guest-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.2rem 0;
  }

  .btn-unassign {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: none;
    background: var(--gray-200);
    color: var(--gray-500);
    font-size: 0.7rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition);
    flex-shrink: 0;
  }

  .btn-unassign:hover {
    background: var(--red);
    color: var(--white);
  }

  /* Fotos */
  .fotos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
  }

  .foto-card {
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    transition: var(--transition);
  }

  .foto-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .foto-card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }

  .foto-card-info {
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .foto-card-meta {
    font-size: 0.8rem;
    color: var(--gray-600);
  }

  .foto-card-meta strong {
    display: block;
    color: var(--gray-800);
  }

  .empty-state {
    text-align: center;
    padding: 3rem;
    color: var(--gray-400);
    font-size: 0.95rem;
  }

  /* Action buttons in table */
  .action-btns {
    display: flex;
    gap: 0.35rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .dash-header { padding: 0.75rem 1rem; }
    .tabs-nav { padding: 0 1rem; }
    .tab-content { padding: 1rem; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .form-inline { flex-direction: column; align-items: stretch; }
    .assign-form { flex-direction: column; align-items: stretch; }
    .card-header { flex-direction: column; align-items: stretch; }
    .fotos-grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); }
    .tab-btn { padding: 0.6rem 1rem; font-size: 0.8rem; }
  }

  @media (max-width: 480px) {
    .stats-grid { grid-template-columns: 1fr; }
    .login-card { padding: 2rem 1.5rem; }
  }
</style>
</body>
</html>
