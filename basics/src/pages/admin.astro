			</div>
			<div class="table-footer">
				<span id="table-count">0 resultados</span>
				<span id="table-people-count">0 pessoas no total</span>
			</div>
		</div>
	</div>

	<!-- Mesas Tab View -->
	<div id="mesas-view" class="tab-view">
		<!-- Error message area -->
		<div id="mesas-error" class="mesas-error" style="display:none;"></div>

		<!-- Create table form -->
		<div class="mesas-create-form">
			<h2 class="mesas-section-title">Gerir Mesas</h2>
			<form id="create-table-form" class="inline-form">
				<input type="text" id="new-table-name" placeholder="Nome da mesa" required class="inline-input" />
				<input type="number" id="new-table-capacity" placeholder="Capacidade" min="1" required class="inline-input inline-input-small" />
				<button type="submit" class="btn-primary">Criar Mesa</button>
			</form>
		</div>

		<!-- Table list -->
		<div class="mesas-list-wrapper">
			<div class="table-scroll">
				<table>
					<thead>
						<tr>
							<th>Nome</th>
							<th>Capacidade</th>
							<th>Ocupação</th>
							<th>Ações</th>
						</tr>
					</thead>
					<tbody id="mesas-table-body"></tbody>
				</table>
			</div>
			<div class="table-footer">
				<span id="mesas-count">0 mesas</span>
			</div>
		</div>

		<!-- Seating Overview Grid -->
		<div class="seating-grid-wrapper">
			<div class="seating-grid-header">
				<h3>Visão Geral das Mesas</h3>
				<span id="seating-grid-unassigned" class="seating-grid-unassigned" style="display:none;">
					<span id="seating-grid-unassigned-count">0</span> sem mesa
				</span>
			</div>
			<div id="seating-grid" class="seating-grid"></div>
		</div>

		<!-- Guest Assignment Section -->
		<div class="guest-assignment-wrapper">
