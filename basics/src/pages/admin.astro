				<h3>Atribuir Convidados a Mesas</h3>
			</div>
			<div class="guest-assignment-search">
				<input type="text" id="guest-assign-search" placeholder="Filtrar convidados por nome..." />
			</div>
			<div class="table-scroll">
				<table>
					<thead>
						<tr>
							<th>#</th>
							<th>Convidado</th>
							<th>Mesa Atribuída</th>
							<th>Estado</th>
						</tr>
