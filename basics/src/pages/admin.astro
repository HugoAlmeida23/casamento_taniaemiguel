			<div class="stat-card">
				<div class="stat-value" id="stat-adults">0</div>
				<div class="stat-label">Adultos</div>
			</div>
			<div class="stat-card">
				<div class="stat-value" id="stat-children">0</div>
				<div class="stat-label">Crianças</div>
			</div>
			<div class="stat-card">
				<div class="stat-value" id="stat-total-people">0</div>
				<div class="stat-label">Total Pessoas</div>
			</div>
		</div>

		<!-- Search -->
		<div class="search-bar">
			<input type="text" id="search-input" placeholder="Pesquisar por nome, telemóvel ou restrição..." />
		</div>

		<!-- Table -->
		<div class="table-wrapper">
			<div class="table-scroll">
				<table>
					<thead>
						<tr>
							<th>#</th>
							<th>Nome</th>
							<th>Telemóvel</th>
							<th>Restrições</th>
							<th>Acompanhantes</th>
							<th>Mensagem</th>
