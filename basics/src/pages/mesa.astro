---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Encontre a sua Mesa — Tânia & Miguel">
  <main class="min-h-screen bg-beige-50">
    <!-- Search Section -->
    <section id="search-section" class="wedding-section flex flex-col items-center justify-center min-h-[60vh]">
      <div class="text-center max-w-lg mx-auto w-full">
        <!-- Page Header -->
        <p class="section-subtitle">Casamento Tânia & Miguel</p>
        <h1 class="font-playfair text-4xl md:text-5xl lg:text-6xl font-light text-gray-900 mb-2">
          Encontre a sua Mesa
        </h1>
        <div class="ornament">
          <span class="text-gold-400 text-lg">✦</span>
        </div>
        <p class="font-montserrat text-olive-600 text-sm md:text-base mt-4 mb-10">
          Insira o seu nome para descobrir onde se vai sentar
        </p>

        <!-- Search Form -->
        <form id="search-form" class="relative w-full max-w-md mx-auto" role="search" aria-label="Pesquisar convidado">
          <div class="relative">
            <input
              id="guest-search-input"
              type="text"
              placeholder="Nome do convidado..."
              autocomplete="off"
              aria-label="Nome do convidado"
              aria-describedby="search-hint"
              class="w-full px-6 py-4 rounded-full border-2 border-beige-300 bg-white font-montserrat text-base text-gray-800 placeholder-olive-400 focus:outline-none focus:border-gold-400 focus:ring-3 focus:ring-gold-100 transition-all duration-300 shadow-sm"
            />
            <button
              type="submit"
              aria-label="Pesquisar"
              class="absolute right-2 top-1/2 -translate-y-1/2 w-11 h-11 flex items-center justify-center rounded-full bg-olive-500 hover:bg-olive-600 text-white transition-colors duration-200"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </button>
          </div>
          <p id="search-hint" class="sr-only">Escreva o seu nome e pressione Enter ou clique no botão de pesquisa</p>
        </form>

        <!-- Live region for screen reader announcements -->
        <div id="search-announcements" class="sr-only" aria-live="polite" aria-atomic="true"></div>

        <!-- Loading State -->
        <div id="search-loading" class="hidden mt-6">
          <div class="flex items-center justify-center gap-2 text-olive-500 font-montserrat text-sm">
            <svg class="animate-spin w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <span>A procurar...</span>
          </div>
        </div>

        <!-- Results Dropdown -->
        <div id="search-results" class="hidden mt-4 w-full max-w-md mx-auto">
          <div class="bg-white rounded-2xl border border-beige-200 shadow-lg overflow-hidden">
            <p class="px-5 py-3 text-xs uppercase tracking-wider text-olive-500 font-montserrat font-medium border-b border-beige-100">
              Selecione o seu nome
            </p>
            <ul id="results-list" role="listbox" aria-label="Resultados da pesquisa" class="max-h-60 overflow-y-auto">
            </ul>
          </div>
        </div>

        <!-- No Results Message -->
        <div id="no-results" class="hidden mt-6">
          <div class="bg-white rounded-2xl border border-beige-200 p-6 max-w-md mx-auto">
            <div class="text-gold-500 text-3xl mb-3">✗</div>
            <p class="font-montserrat text-gray-700 text-sm leading-relaxed">
              Não encontrámos esse nome.<br>
              <span class="text-olive-500">Verifique a ortografia ou tente o nome completo.</span>
            </p>
          </div>
        </div>

        <!-- Error Message -->
        <div id="search-error" class="hidden mt-6">
          <div class="bg-white rounded-2xl border border-red-200 p-6 max-w-md mx-auto">
            <p class="font-montserrat text-red-600 text-sm">
              Não foi possível carregar os dados. Tente novamente.
            </p>
            <button id="retry-btn" class="mt-3 px-5 py-3 min-h-[44px] rounded-full bg-olive-500 text-white font-montserrat text-sm hover:bg-olive-600 transition-colors">
              Tentar novamente
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Seating Map Section -->
    <section id="seating-map-section" class="hidden wedding-section" aria-label="Mapa de mesas do casamento">
      <div id="map-announcements" class="sr-only" aria-live="polite" aria-atomic="true"></div>
      <div class="max-w-6xl mx-auto">
        <div class="section-header">
          <h2 class="font-playfair text-2xl md:text-3xl font-light text-gray-900 mb-2">Mapa de Mesas</h2>
          <div class="ornament">
            <span class="text-gold-400 text-sm">✦</span>
          </div>
        </div>

        <!-- SVG Floor Plan Container -->
        <div id="floor-plan-viewport" class="floor-plan-viewport">
          <div id="floor-plan-container" class="floor-plan-container">
            <svg id="floor-plan-svg" viewBox="0 0 1000 700" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Planta do salão com mesas do casamento">
              <!-- Background -->
              <rect width="1000" height="700" fill="#faf8f3" rx="12"/>

              <!-- Dance Floor -->
              <g id="dance-floor">
                <rect x="380" y="260" width="240" height="180" rx="8" fill="#f0ebe0" stroke="#c5c2a5" stroke-width="1.5" stroke-dasharray="6 4"/>
                <text x="500" y="345" text-anchor="middle" font-family="Playfair Display, serif" font-size="16" fill="#8f8a5e" font-style="italic">Pista de</text>
                <text x="500" y="367" text-anchor="middle" font-family="Playfair Display, serif" font-size="16" fill="#8f8a5e" font-style="italic">Dança</text>
              </g>

              <!-- Decorative elements -->
              <circle cx="500" cy="355" r="20" fill="none" stroke="#e0dcc8" stroke-width="0.5" stroke-dasharray="3 3"/>
              <circle cx="500" cy="355" r="35" fill="none" stroke="#e0dcc8" stroke-width="0.5" stroke-dasharray="3 3"/>

              <!-- Tables will be rendered here dynamically -->
              <g id="tables-group"></g>
            </svg>
          </div>

          <!-- Detail Overlay (inside viewport for absolute positioning) -->
          <div id="table-detail-overlay" class="table-detail-overlay hidden">
            <div class="table-detail-content">
              <h3 id="detail-table-name" class="table-detail-heading"></h3>
              <div id="detail-guest-list" class="table-detail-guests"></div>
            </div>
          </div>
        </div>

        <!-- Map Controls -->
        <div id="map-controls" class="hidden mt-6 text-center">
          <button id="back-to-overview-btn" class="inline-flex items-center gap-2 px-5 py-3 min-h-[44px] rounded-full border border-olive-300 text-olive-600 font-montserrat text-sm hover:bg-olive-50 transition-colors focus-visible:outline-2 focus-visible:outline-olive-500 focus-visible:outline-offset-2" aria-label="Voltar à vista geral das mesas">
            ← Ver todas as mesas
          </button>
        </div>

        <!-- Link to ementa section -->
        <div id="ementa-link" class="mt-8 text-center">
          <a href="#ementa-section" id="scroll-to-ementa" class="inline-flex items-center gap-2 font-montserrat text-sm text-olive-500 hover:text-gold-600 transition-colors group" aria-label="Ver ementa do casamento">
            <span>Ver Ementa</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:translate-y-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Ementa Section -->
    <section id="ementa-section" class="hidden wedding-section bg-white py-16 md:py-24" aria-labelledby="ementa-heading">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-12 md:mb-16">
          <p class="font-montserrat text-olive-500 text-xs uppercase tracking-[0.2em] mb-3">Menu do Casamento</p>
          <h2 id="ementa-heading" class="font-playfair text-3xl md:text-4xl lg:text-5xl font-light text-gray-900 mb-3">Ementa</h2>
          <div class="flex items-center justify-center gap-3 mb-4">
            <span class="block w-12 h-px bg-gold-300"></span>
            <span class="text-gold-400 text-sm">✦</span>
            <span class="block w-12 h-px bg-gold-300"></span>
          </div>
          <p class="font-montserrat text-olive-600 text-sm max-w-md mx-auto">
            Uma seleção cuidada de sabores para celebrar este dia especial
          </p>
        </div>

        <div class="ementa-courses space-y-10 md:space-y-14">
          <!-- Entradas -->
          <div class="ementa-course">
            <div class="text-center mb-6">
              <h3 class="font-playfair text-xl md:text-2xl text-gray-900 mb-1">Entradas</h3>
              <span class="block w-8 h-px bg-gold-300 mx-auto"></span>
            </div>
            <ul class="ementa-items space-y-3">
              <li class="ementa-item">
                <span class="ementa-item-name">Tábua de Queijos e Enchidos da Região</span>
                <span class="ementa-item-dot"></span>
                <span class="ementa-item-desc">Seleção artesanal com mel e frutos secos</span>
              </li>
              <li class="ementa-item">
                <span class="ementa-item-name">Alheira Frita com Grelos Salteados</span>
                <span class="ementa-item-dot"></span>
                <span class="ementa-item-desc">Receita tradicional portuguesa</span>
              </li>
              <li class="ementa-item">
                <span class="ementa-item-name">Gambas ao Alho com Coentros</span>
                <span class="ementa-item-dot"></span>
                <span class="ementa-item-desc">Servidas com pão torrado caseiro</span>
              </li>
              <li class="ementa-item">
                <span class="ementa-item-name">Salada de Polvo Grelhado</span>
                <span class="ementa-item-dot"></span>
                <span class="ementa-item-desc">Com batata, cebola roxa e azeite virgem</span>
              </li>
            </ul>
          </div>

          <!-- Prato Principal -->
          <div class="ementa-course">
            <div class="text-center mb-6">
              <h3 class="font-playfair text-xl md:text-2xl text-gray-900 mb-1">Prato Principal</h3>
              <span class="block w-8 h-px bg-gold-300 mx-auto"></span>
            </div>
            <ul class="ementa-items space-y-3">
              <li class="ementa-item">
                <span class="ementa-item-name">Lombo de Vitela Assado com Ervas</span>
                <span class="ementa-item-dot"></span>
                <span class="ementa-item-desc">Acompanhado de puré de batata trufado</span>
              </li>
              <li class="ementa-item">
                <span class="ementa-item-name">Bacalhau com Broa e Espinafres</span>
                <span class="ementa-item-dot"></span>
                <span class="ementa-item-desc">Gratinado no forno com azeite da casa</span>
              </li>
            </ul>
          </div>

          <!-- Sobremesa -->
          <div class="ementa-course">
            <div class="text-center mb-6">
              <h3 class="font-playfair text-xl md:text-2xl text-gray-900 mb-1">Sobremesa</h3>
              <span class="block w-8 h-px bg-gold-300 mx-auto"></span>
            </div>
            <ul class="ementa-items space-y-3">
              <li class="ementa-item">
                <span class="ementa-item-name">Bolo de Noiva</span>
                <span class="ementa-item-dot"></span>
                <span class="ementa-item-desc">Camadas de baunilha com creme de framboesa</span>
              </li>
              <li class="ementa-item">
                <span class="ementa-item-name">Leite-Creme Queimado</span>
                <span class="ementa-item-dot"></span>
                <span class="ementa-item-desc">Receita conventual com canela</span>
              </li>
              <li class="ementa-item">
                <span class="ementa-item-name">Mesa de Doces Regionais</span>
                <span class="ementa-item-dot"></span>
                <span class="ementa-item-desc">Pastéis de nata, travesseiros e queijadas</span>
              </li>
            </ul>
          </div>

          <!-- Bebidas -->
          <div class="ementa-course">
            <div class="text-center mb-6">
              <h3 class="font-playfair text-xl md:text-2xl text-gray-900 mb-1">Bebidas</h3>
              <span class="block w-8 h-px bg-gold-300 mx-auto"></span>
            </div>
            <ul class="ementa-items space-y-3">
              <li class="ementa-item">
                <span class="ementa-item-name">Espumante de Boas-Vindas</span>
                <span class="ementa-item-dot"></span>
                <span class="ementa-item-desc">Bruto natural da região</span>
              </li>
              <li class="ementa-item">
                <span class="ementa-item-name">Vinho Branco e Tinto da Quinta</span>
                <span class="ementa-item-dot"></span>
                <span class="ementa-item-desc">Seleção do enólogo para a ocasião</span>
              </li>
              <li class="ementa-item">
                <span class="ementa-item-name">Águas, Sumos Naturais e Café</span>
                <span class="ementa-item-dot"></span>
                <span class="ementa-item-desc">Disponíveis durante toda a refeição</span>
              </li>
            </ul>
          </div>
        </div>

        <div class="text-center mt-12 md:mt-16">
          <div class="flex items-center justify-center gap-3">
            <span class="block w-8 h-px bg-beige-300"></span>
            <span class="text-gold-400 text-xs">✦ ✦ ✦</span>
            <span class="block w-8 h-px bg-beige-300"></span>
          </div>
          <p class="font-montserrat text-olive-500 text-xs mt-4 italic">
            Menu sujeito a pequenas alterações sazonais
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  // --- Types ---
  interface Guest {
    id: string;
    nome: string;
    mesa_id: string | null;
    [key: string]: unknown;
  }

  interface Table {
    id: string;
    name: string;
    capacity: number;
  }

  interface TablePosition {
    x: number;
    y: number;
    radius: number;
  }

  // --- State ---
  let allGuests: Guest[] = [];
  let allTables: Table[] = [];
  let guestsFetched = false;
  let tablesFetched = false;
  let selectedGuest: Guest | null = null;
  let mapRendered = false;
  let currentView: 'overview' | 'detail' = 'overview';
  let activeTableId: string | null = null;

  // --- Table layout positions (scattered around dance floor) ---
  // Positions are well within the 1000x700 viewBox to avoid clipping
  const TABLE_POSITIONS: TablePosition[] = [
    // Top row (3 tables)
    { x: 200, y: 130, radius: 38 },
    { x: 500, y: 120, radius: 38 },
    { x: 800, y: 130, radius: 38 },
    // Left side (2 tables)
    { x: 160, y: 330, radius: 38 },
    { x: 170, y: 530, radius: 38 },
    // Right side (2 tables)
    { x: 840, y: 330, radius: 38 },
    { x: 830, y: 530, radius: 38 },
    // Bottom row (2 tables)
    { x: 300, y: 600, radius: 36 },
    { x: 700, y: 600, radius: 36 },
    // Inner ring near dance floor (5 tables)
    { x: 320, y: 210, radius: 34 },
    { x: 680, y: 210, radius: 34 },
    { x: 280, y: 450, radius: 34 },
    { x: 720, y: 450, radius: 34 },
    { x: 500, y: 580, radius: 34 },
  ];

  // --- DOM Elements ---
  const searchForm = document.getElementById('search-form') as HTMLFormElement;
  const searchInput = document.getElementById('guest-search-input') as HTMLInputElement;
  const searchLoading = document.getElementById('search-loading') as HTMLElement;
  const searchResults = document.getElementById('search-results') as HTMLElement;
  const resultsList = document.getElementById('results-list') as HTMLUListElement;
  const noResults = document.getElementById('no-results') as HTMLElement;
  const searchError = document.getElementById('search-error') as HTMLElement;
  const retryBtn = document.getElementById('retry-btn') as HTMLButtonElement;
  const seatingMapSection = document.getElementById('seating-map-section') as HTMLElement;
  const ementaSection = document.getElementById('ementa-section') as HTMLElement;
  const scrollToEmentaLink = document.getElementById('scroll-to-ementa') as HTMLAnchorElement;
  const searchAnnouncements = document.getElementById('search-announcements') as HTMLElement;
  const mapAnnouncements = document.getElementById('map-announcements') as HTMLElement;
  const floorPlanContainer = document.getElementById('floor-plan-container') as HTMLElement;
  const floorPlanSvg = document.getElementById('floor-plan-svg') as unknown as SVGSVGElement;
  const tablesGroup = document.getElementById('tables-group') as unknown as SVGGElement;
  const detailOverlay = document.getElementById('table-detail-overlay') as HTMLElement;
  const detailTableName = document.getElementById('detail-table-name') as HTMLElement;
  const detailGuestList = document.getElementById('detail-guest-list') as HTMLElement;
  const mapControls = document.getElementById('map-controls') as HTMLElement;
  const backToOverviewBtn = document.getElementById('back-to-overview-btn') as HTMLButtonElement;
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // --- Utility functions ---
  function searchGuestsByName(guests: Guest[], query: string): Guest[] {
    if (query.trim() === '') return [];
    const lowerQuery = query.trim().toLowerCase();
    return guests.filter((guest) => guest.nome.toLowerCase().includes(lowerQuery));
  }

  function announceToSearch(message: string) {
    searchAnnouncements.textContent = message;
  }

  function announceToMap(message: string) {
    mapAnnouncements.textContent = message;
  }

  // --- UI Helpers ---
  function hideAllMessages() {
    searchLoading.classList.add('hidden');
    searchResults.classList.add('hidden');
    noResults.classList.add('hidden');
    searchError.classList.add('hidden');
  }

  function showLoading() {
    hideAllMessages();
    searchLoading.classList.remove('hidden');
  }

  function showResults(guests: Guest[]) {
    hideAllMessages();
    searchResults.classList.remove('hidden');
    resultsList.innerHTML = '';
    announceToSearch(`${guests.length} resultados encontrados. Use as setas para navegar.`);

    guests.forEach((guest) => {
      const li = document.createElement('li');
      li.role = 'option';
      li.tabIndex = 0;
      li.className = 'px-5 py-3 font-montserrat text-sm text-gray-800 hover:bg-beige-50 cursor-pointer transition-colors border-b border-beige-50 last:border-b-0 flex items-center justify-between';
      li.setAttribute('data-guest-id', guest.id);
      li.innerHTML = `
        <span>${guest.nome}</span>
        <span class="text-olive-400 text-xs">${guest.mesa_id ? '●' : ''}</span>
      `;
      li.addEventListener('click', () => selectGuest(guest));
      li.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          selectGuest(guest);
        }
      });
      resultsList.appendChild(li);
    });
  }

  function showNoResults() {
    hideAllMessages();
    noResults.classList.remove('hidden');
    announceToSearch('Nenhum resultado encontrado. Verifique a ortografia.');
  }

  function showError() {
    hideAllMessages();
    searchError.classList.remove('hidden');
    announceToSearch('Erro ao carregar dados. Tente novamente.');
  }

  // --- API calls ---
  async function fetchGuests(): Promise<Guest[]> {
    if (guestsFetched && allGuests.length > 0) return allGuests;
    const response = await fetch('/api/guests');
    if (!response.ok) throw new Error(`API error: ${response.status}`);
    const data = await response.json();
    allGuests = data;
    guestsFetched = true;
    return allGuests;
  }

  async function fetchTables(): Promise<Table[]> {
    if (tablesFetched && allTables.length > 0) return allTables;
    const response = await fetch('/api/tables');
    if (!response.ok) throw new Error(`API error: ${response.status}`);
    const data = await response.json();
    allTables = data;
    tablesFetched = true;
    return allTables;
  }

  // --- SVG Floor Plan Rendering ---

  function createSvgElement(tag: string, attrs: Record<string, string>): SVGElement {
    const el = document.createElementNS('http://www.w3.org/2000/svg', tag);
    for (const [key, value] of Object.entries(attrs)) {
      el.setAttribute(key, value);
    }
    return el;
  }

  /**
   * Renders a single table as an SVG group with seats arranged around it.
   */
  function renderTable(table: Table, position: TablePosition, tableGuests: Guest[], index: number): SVGGElement {
    const { x, y, radius } = position;
    const group = createSvgElement('g', {
      'data-table-id': table.id,
      'class': 'floor-table',
      'role': 'button',
      'tabindex': '0',
      'aria-label': `${table.name}, ${tableGuests.length} de ${table.capacity} lugares ocupados`,
    }) as SVGGElement;

    // Table surface (large circle)
    const tableCircle = createSvgElement('circle', {
      cx: String(x),
      cy: String(y),
      r: String(radius),
      fill: '#f5f0e3',
      stroke: '#c5c2a5',
      'stroke-width': '1.5',
      class: 'table-surface',
    });
    group.appendChild(tableCircle);

    // Inner decorative ring
    const innerRing = createSvgElement('circle', {
      cx: String(x),
      cy: String(y),
      r: String(radius - 10),
      fill: 'none',
      stroke: '#e8e4d4',
      'stroke-width': '0.5',
      'stroke-dasharray': '2 2',
    });
    group.appendChild(innerRing);

    // Seat circles arranged around the table
    const seatRadius = 7;
    const seatDistance = radius + 14;
    const totalSeats = table.capacity;

    for (let i = 0; i < totalSeats; i++) {
      const angle = (i / totalSeats) * Math.PI * 2 - Math.PI / 2;
      const seatX = x + Math.cos(angle) * seatDistance;
      const seatY = y + Math.sin(angle) * seatDistance;

      const isOccupied = i < tableGuests.length;
      const isCurrentGuest = isOccupied && selectedGuest && tableGuests[i].id === selectedGuest.id;

      // Determine colors inline for SVG compatibility
      let seatFill: string;
      let seatStroke: string;
      let seatStrokeWidth: string;
      let seatStrokeDasharray: string = 'none';

      if (isCurrentGuest) {
        seatFill = '#e6b040';
        seatStroke = '#d4983a';
        seatStrokeWidth = '1.5';
      } else if (isOccupied) {
        seatFill = '#c5c2a5';
        seatStroke = '#a9a57e';
        seatStrokeWidth = '1';
      } else {
        seatFill = '#fdfcf9';
        seatStroke = '#c5c2a5';
        seatStrokeWidth = '1';
        seatStrokeDasharray = '3 2';
      }

      const seatAttrs: Record<string, string> = {
        cx: String(seatX),
        cy: String(seatY),
        r: String(seatRadius),
        fill: seatFill,
        stroke: seatStroke,
        'stroke-width': seatStrokeWidth,
      };
      if (seatStrokeDasharray !== 'none') {
        seatAttrs['stroke-dasharray'] = seatStrokeDasharray;
      }

      const seat = createSvgElement('circle', seatAttrs);

      if (isCurrentGuest) {
        seat.setAttribute('data-guest-seat', 'true');
      }

      group.appendChild(seat);
    }

    // Table name text
    const tableName = createSvgElement('text', {
      x: String(x),
      y: String(y + 1),
      'text-anchor': 'middle',
      'dominant-baseline': 'middle',
      'font-family': 'Montserrat, sans-serif',
      'font-size': '9',
      'font-weight': '600',
      fill: '#74704a',
      'pointer-events': 'none',
    });
    tableName.textContent = table.name;
    group.appendChild(tableName);

    return group;
  }

  /**
   * Renders the full floor plan SVG with all tables.
   */
  function renderFloorPlan(tables: Table[]) {
    tablesGroup.innerHTML = '';

    if (tables.length === 0) {
      const emptyText = createSvgElement('text', {
        x: '500',
        y: '350',
        'text-anchor': 'middle',
        'font-family': 'Montserrat, sans-serif',
        'font-size': '14',
        fill: '#8f8a5e',
      });
      emptyText.textContent = 'O mapa de mesas será disponibilizado em breve.';
      tablesGroup.appendChild(emptyText);
      return;
    }

    // Group guests by table
    const guestsByTable = new Map<string, Guest[]>();
    tables.forEach(t => guestsByTable.set(t.id, []));
    allGuests.forEach(g => {
      if (g.mesa_id && guestsByTable.has(g.mesa_id)) {
        guestsByTable.get(g.mesa_id)!.push(g);
      }
    });

    tables.forEach((table, index) => {
      const position = TABLE_POSITIONS[index % TABLE_POSITIONS.length];
      const tableGuests = guestsByTable.get(table.id) || [];
      const tableGroup = renderTable(table, position, tableGuests, index);
      tablesGroup.appendChild(tableGroup);
    });
  }

  // --- Zoom Logic ---

  function getTablePosition(tableId: string): TablePosition | null {
    const tableIndex = allTables.findIndex(t => t.id === tableId);
    if (tableIndex === -1) return null;
    return TABLE_POSITIONS[tableIndex % TABLE_POSITIONS.length];
  }

  function zoomToTable(tableId: string) {
    const position = getTablePosition(tableId);
    if (!position) return;

    currentView = 'detail';
    activeTableId = tableId;

    // Calculate zoom transform to center on the table
    // SVG viewBox is 1000x700, we want to zoom to ~3x and center on the table
    const scale = 2.5;
    const viewportWidth = floorPlanContainer.clientWidth;
    const viewportHeight = floorPlanContainer.clientHeight;

    // The SVG scales to fit the container, so we need to calculate based on the container
    const svgScaleX = viewportWidth / 1000;
    const svgScaleY = viewportHeight / 700;
    const svgScale = Math.min(svgScaleX, svgScaleY);

    // Table position in pixel space
    const tablePxX = position.x * svgScale;
    const tablePxY = position.y * svgScale;

    // Center of viewport
    const centerX = viewportWidth / 2;
    const centerY = viewportHeight / 2;

    // Translation needed to center the table, then scale
    const translateX = centerX - tablePxX * scale;
    const translateY = centerY - tablePxY * scale;

    if (!prefersReducedMotion) {
      floorPlanContainer.style.transition = 'transform 0.8s cubic-bezier(0.4, 0, 0.2, 1)';
    } else {
      floorPlanContainer.style.transition = 'none';
    }

    floorPlanContainer.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
    floorPlanContainer.style.transformOrigin = '0 0';

    // Highlight the active table
    const allTableGroups = tablesGroup.querySelectorAll('.floor-table');
    allTableGroups.forEach(g => g.classList.remove('table-active'));
    const targetGroup = tablesGroup.querySelector(`[data-table-id="${tableId}"]`);
    if (targetGroup) {
      targetGroup.classList.add('table-active');
    }

    // Show controls
    mapControls.classList.remove('hidden');
  }

  function zoomToOverview() {
    currentView = 'overview';
    activeTableId = null;

    if (!prefersReducedMotion) {
      floorPlanContainer.style.transition = 'transform 0.8s cubic-bezier(0.4, 0, 0.2, 1)';
    } else {
      floorPlanContainer.style.transition = 'none';
    }

    floorPlanContainer.style.transform = 'translate(0, 0) scale(1)';

    // Remove active highlights
    const allTableGroups = tablesGroup.querySelectorAll('.floor-table');
    allTableGroups.forEach(g => g.classList.remove('table-active'));

    // Hide detail overlay and controls
    hideDetailOverlay();
    mapControls.classList.add('hidden');
  }

  // --- Detail Overlay ---

  function showDetailOverlay(tableId: string) {
    const table = allTables.find(t => t.id === tableId);
    if (!table) return;

    const tableGuests = allGuests.filter(g => g.mesa_id === tableId);

    detailTableName.textContent = table.name;
    detailGuestList.innerHTML = '';

    if (tableGuests.length === 0) {
      detailGuestList.innerHTML = '<p class="text-olive-400 text-sm italic">Sem convidados atribuídos</p>';
    } else {
      tableGuests.forEach(guest => {
        const guestEl = document.createElement('div');
        const isHighlighted = selectedGuest && guest.id === selectedGuest.id;
        guestEl.className = `detail-guest-item ${isHighlighted ? 'detail-guest-highlighted' : ''}`;
        guestEl.innerHTML = `
          <span class="detail-guest-dot ${isHighlighted ? 'dot-gold' : ''}"></span>
          <span class="detail-guest-name">${guest.nome}</span>
        `;
        detailGuestList.appendChild(guestEl);
      });
    }

    // Announce to screen readers
    const guestNames = tableGuests.map(g => g.nome).join(', ');
    announceToMap(`${table.name}. ${tableGuests.length} convidados: ${guestNames || 'Sem convidados'}`);

    detailOverlay.classList.remove('hidden');
    requestAnimationFrame(() => {
      detailOverlay.classList.add('visible');
    });
  }

  function hideDetailOverlay() {
    detailOverlay.classList.remove('visible');
    setTimeout(() => {
      detailOverlay.classList.add('hidden');
    }, 300);
  }

  // --- Show seating map ---

  async function showSeatingMap() {
    if (mapRendered) return;

    try {
      const [tables] = await Promise.all([fetchTables(), fetchGuests()]);
      renderFloorPlan(tables);
      mapRendered = true;
      seatingMapSection.classList.add('map-visible');
    } catch (error) {
      tablesGroup.innerHTML = '';
      const errorText = createSvgElement('text', {
        x: '500',
        y: '350',
        'text-anchor': 'middle',
        'font-family': 'Montserrat, sans-serif',
        'font-size': '14',
        fill: '#c0392b',
      });
      errorText.textContent = 'Não foi possível carregar o mapa de mesas.';
      tablesGroup.appendChild(errorText);
    }
  }

  // --- Auto-zoom after guest selection ---

  function triggerAutoZoom() {
    if (!selectedGuest) return;

    if (!selectedGuest.mesa_id) {
      showNoTableAssigned();
      return;
    }

    const tableId = selectedGuest.mesa_id;

    if (prefersReducedMotion) {
      zoomToTable(tableId);
      showDetailOverlay(tableId);
    } else {
      setTimeout(() => {
        zoomToTable(tableId);
        // Show detail after zoom animation completes
        setTimeout(() => {
          showDetailOverlay(tableId);
        }, 850);
      }, 1500);
    }
  }

  function showNoTableAssigned() {
    detailTableName.textContent = '';
    detailGuestList.innerHTML = `
      <div class="text-center py-4">
        <div class="text-gold-400 text-3xl mb-3">✦</div>
        <p class="font-montserrat text-gray-700 text-sm leading-relaxed">
          A sua mesa ainda não foi atribuída.
        </p>
        <p class="font-montserrat text-olive-500 text-xs mt-2">
          Volte mais tarde para descobrir onde se vai sentar.
        </p>
      </div>
    `;
    detailOverlay.classList.remove('hidden');
    requestAnimationFrame(() => {
      detailOverlay.classList.add('visible');
    });
    announceToMap('A sua mesa ainda não foi atribuída. Volte mais tarde.');
  }

  // --- Guest selection ---

  function selectGuest(guest: Guest) {
    selectedGuest = guest;
    hideAllMessages();
    announceToSearch(`${guest.nome} selecionado. A mostrar mapa de mesas.`);

    const event = new CustomEvent('guest-selected', { detail: { guest } });
    document.dispatchEvent(event);

    seatingMapSection.classList.remove('hidden');
    ementaSection.classList.remove('hidden');
    seatingMapSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // --- Search handler ---

  async function handleSearch(query: string) {
    if (query.trim() === '') {
      hideAllMessages();
      return;
    }

    showLoading();

    try {
      const guests = await fetchGuests();
      const matches = searchGuestsByName(guests, query);

      if (matches.length === 0) {
        showNoResults();
      } else if (matches.length === 1) {
        selectGuest(matches[0]);
      } else {
        showResults(matches);
      }
    } catch (error) {
      showError();
    }
  }

  // --- Table click navigation ---

  function navigateToTable(tableId: string) {
    if (currentView === 'overview') {
      zoomToTable(tableId);
      const delay = prefersReducedMotion ? 0 : 850;
      setTimeout(() => showDetailOverlay(tableId), delay);
    } else if (currentView === 'detail') {
      hideDetailOverlay();
      const allTableGroups = tablesGroup.querySelectorAll('.floor-table');
      allTableGroups.forEach(g => g.classList.remove('table-active'));

      if (prefersReducedMotion) {
        zoomToTable(tableId);
        showDetailOverlay(tableId);
      } else {
        zoomToOverview();
        setTimeout(() => {
          zoomToTable(tableId);
          setTimeout(() => showDetailOverlay(tableId), 850);
        }, 500);
      }
    }
  }

  // --- Event Listeners ---

  searchForm.addEventListener('submit', (e: Event) => {
    e.preventDefault();
    handleSearch(searchInput.value);
  });

  searchInput.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') {
      hideAllMessages();
      searchInput.value = '';
    }
  });

  retryBtn.addEventListener('click', () => {
    guestsFetched = false;
    allGuests = [];
    const query = searchInput.value;
    if (query.trim()) handleSearch(query);
  });

  backToOverviewBtn.addEventListener('click', () => {
    zoomToOverview();
    announceToMap('Vista geral das mesas');
  });

  // Table click/keyboard in SVG
  tablesGroup.addEventListener('click', (e: Event) => {
    const target = (e.target as Element).closest('.floor-table');
    if (!target) return;
    const tableId = target.getAttribute('data-table-id');
    if (tableId) navigateToTable(tableId);
  });

  tablesGroup.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key !== 'Enter' && e.key !== ' ') return;
    const target = (e.target as Element).closest('.floor-table');
    if (!target) return;
    const tableId = target.getAttribute('data-table-id');
    if (tableId) {
      e.preventDefault();
      navigateToTable(tableId);
    }
  });

  // Escape to return to overview
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && currentView === 'detail') {
      e.preventDefault();
      zoomToOverview();
      announceToMap('Vista geral das mesas');
    }
  });

  // Guest selected event triggers map
  document.addEventListener('guest-selected', ((event: CustomEvent) => {
    showSeatingMap().then(() => {
      // Re-render to update seat highlights for the selected guest
      if (mapRendered) {
        renderFloorPlan(allTables);
      }
      triggerAutoZoom();
    });
  }) as EventListener);

  // Smooth scroll to ementa
  scrollToEmentaLink.addEventListener('click', (e: MouseEvent) => {
    e.preventDefault();
    ementaSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>

