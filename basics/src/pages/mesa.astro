---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Encontre a sua Mesa — Tânia & Miguel">
  <main id="mesa-main">
    <!-- SEARCH SCREEN — full screen centered -->
    <section id="search-section">
      <div class="search-inner">
        <p class="search-subtitle">Casamento Tânia & Miguel</p>
        <h1 class="search-title">Encontre a sua Mesa</h1>
        <div class="search-ornament">
          <span>✦</span>
        </div>
        <p class="search-desc">Insira o seu nome para descobrir onde se vai sentar</p>

        <form id="search-form" role="search" aria-label="Pesquisar convidado">
          <div class="search-input-wrap">
            <input
              id="guest-search-input"
              type="text"
              placeholder="Nome do convidado..."
              autocomplete="off"
              aria-label="Nome do convidado"
            />
            <button type="submit" aria-label="Pesquisar">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </button>
          </div>
        </form>

        <!-- Loading -->
        <div id="search-loading" class="search-msg hidden">
          <div class="loading-spinner"></div>
          <span>A procurar...</span>
        </div>

        <!-- Results -->
        <div id="search-results" class="hidden">
          <div class="results-box">
            <p class="results-label">Selecione o seu nome</p>
            <ul id="results-list" role="listbox" aria-label="Resultados"></ul>
          </div>
        </div>

        <!-- No results -->
        <div id="no-results" class="search-msg hidden">
          <div class="msg-icon">✗</div>
          <p>Não encontrámos esse nome.<br><span class="msg-hint">Verifique a ortografia ou tente o nome completo.</span></p>
        </div>

        <!-- Error -->
        <div id="search-error" class="search-msg hidden">
          <p class="msg-error">Não foi possível carregar os dados.</p>
          <button id="retry-btn">Tentar novamente</button>
        </div>
      </div>

      <!-- Live region -->
      <div id="search-announcements" class="sr-only" aria-live="polite" aria-atomic="true"></div>
    </section>

    <!-- MAP SECTION — shows below search after guest is found -->
    <section id="map-section" class="hidden">
      <div id="map-announcements" class="sr-only" aria-live="polite" aria-atomic="true"></div>

      <!-- Section header -->
      <div class="map-header">
        <h2 class="map-title">Mapa de Mesas</h2>
        <div class="map-ornament"><span>✦</span></div>
      </div>

      <!-- SVG Floor Plan Viewport -->
      <div id="floor-plan-viewport">
        <div id="floor-plan-container">
          <svg id="floor-plan-svg" viewBox="0 0 1000 700" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Planta do salão com mesas">
            <rect width="1000" height="700" fill="#faf8f3" rx="12"/>
            <!-- Dance Floor -->
            <rect x="380" y="260" width="240" height="180" rx="8" fill="#f0ebe0" stroke="#c5c2a5" stroke-width="1.5" stroke-dasharray="6 4"/>
            <text x="500" y="345" text-anchor="middle" font-family="Playfair Display, serif" font-size="16" fill="#8f8a5e" font-style="italic">Pista de</text>
            <text x="500" y="367" text-anchor="middle" font-family="Playfair Display, serif" font-size="16" fill="#8f8a5e" font-style="italic">Dança</text>
            <circle cx="500" cy="355" r="20" fill="none" stroke="#e0dcc8" stroke-width="0.5" stroke-dasharray="3 3"/>
            <circle cx="500" cy="355" r="35" fill="none" stroke="#e0dcc8" stroke-width="0.5" stroke-dasharray="3 3"/>
            <g id="tables-group"></g>
          </svg>
        </div>
      </div>

      <!-- Ver Ementa link below map -->
      <div id="ementa-link">
        <a href="#ementa-section" id="scroll-to-ementa">
          <span>Ver Ementa</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
      </div>
    </section>

    <!-- BOTTOM SHEET (mobile) / SIDEBAR OVERLAY (desktop) -->
    <div id="detail-sheet" class="detail-sheet hidden" aria-hidden="true">
      <div class="sheet-drag-handle"><span></span></div>
      <button id="back-to-overview-btn" class="sheet-back-btn" aria-label="Voltar à vista geral das mesas">
        ← Ver todas as mesas
      </button>
      <div class="sheet-content">
        <h3 id="detail-table-name" class="sheet-table-name"></h3>
        <div id="detail-guest-list" class="sheet-guest-list"></div>
      </div>
    </div>

    <!-- Ementa Section -->
    <section id="ementa-section" class="hidden" aria-labelledby="ementa-heading">
      <div class="ementa-wrapper">
        <div class="ementa-header">
          <p class="ementa-label">Menu do Casamento</p>
          <h2 id="ementa-heading" class="ementa-title">Ementa</h2>
          <div class="ementa-ornament">
            <span class="ementa-line"></span>
            <span class="ementa-star">✦</span>
            <span class="ementa-line"></span>
          </div>
          <p class="ementa-subtitle">Uma seleção cuidada de sabores para celebrar este dia especial</p>
        </div>

        <div class="ementa-courses">
          <!-- Entradas -->
          <div class="ementa-course">
            <div class="course-header">
              <h3>Entradas</h3>
              <span class="course-line"></span>
            </div>
            <ul>
              <li><span class="item-name">Tábua de Queijos e Enchidos da Região</span><span class="item-dot"></span><span class="item-desc">Seleção artesanal com mel e frutos secos</span></li>
              <li><span class="item-name">Alheira Frita com Grelos Salteados</span><span class="item-dot"></span><span class="item-desc">Receita tradicional portuguesa</span></li>
              <li><span class="item-name">Gambas ao Alho com Coentros</span><span class="item-dot"></span><span class="item-desc">Servidas com pão torrado caseiro</span></li>
              <li><span class="item-name">Salada de Polvo Grelhado</span><span class="item-dot"></span><span class="item-desc">Com batata, cebola roxa e azeite virgem</span></li>
            </ul>
          </div>

          <!-- Prato Principal -->
          <div class="ementa-course">
            <div class="course-header">
              <h3>Prato Principal</h3>
              <span class="course-line"></span>
            </div>
            <ul>
              <li><span class="item-name">Lombo de Vitela Assado com Ervas</span><span class="item-dot"></span><span class="item-desc">Acompanhado de puré de batata trufado</span></li>
              <li><span class="item-name">Bacalhau com Broa e Espinafres</span><span class="item-dot"></span><span class="item-desc">Gratinado no forno com azeite da casa</span></li>
            </ul>
          </div>

          <!-- Sobremesa -->
          <div class="ementa-course">
            <div class="course-header">
              <h3>Sobremesa</h3>
              <span class="course-line"></span>
            </div>
            <ul>
              <li><span class="item-name">Bolo de Noiva</span><span class="item-dot"></span><span class="item-desc">Camadas de baunilha com creme de framboesa</span></li>
              <li><span class="item-name">Leite-Creme Queimado</span><span class="item-dot"></span><span class="item-desc">Receita conventual com canela</span></li>
              <li><span class="item-name">Mesa de Doces Regionais</span><span class="item-dot"></span><span class="item-desc">Pastéis de nata, travesseiros e queijadas</span></li>
            </ul>
          </div>

          <!-- Bebidas -->
          <div class="ementa-course">
            <div class="course-header">
              <h3>Bebidas</h3>
              <span class="course-line"></span>
            </div>
            <ul>
              <li><span class="item-name">Espumante de Boas-Vindas</span><span class="item-dot"></span><span class="item-desc">Bruto natural da região</span></li>
              <li><span class="item-name">Vinho Branco e Tinto da Quinta</span><span class="item-dot"></span><span class="item-desc">Seleção do enólogo para a ocasião</span></li>
              <li><span class="item-name">Águas, Sumos Naturais e Café</span><span class="item-dot"></span><span class="item-desc">Disponíveis durante toda a refeição</span></li>
            </ul>
          </div>
        </div>

        <div class="ementa-footer">
          <span class="ementa-line"></span>
          <span class="ementa-stars">✦ ✦ ✦</span>
          <span class="ementa-line"></span>
        </div>
        <p class="ementa-note">Menu sujeito a pequenas alterações sazonais</p>
      </div>
    </section>
  </main>
</Layout>

<script>
  // === Types ===
  interface Guest {
    id: string;
    nome: string;
    mesa_id: string | null;
    [key: string]: unknown;
  }

  interface Table {
    id: string;
    name: string;
    capacity: number;
  }

  interface TablePosition {
    x: number;
    y: number;
    radius: number;
  }

  // === State ===
  let allGuests: Guest[] = [];
  let allTables: Table[] = [];
  let guestsFetched = false;
  let tablesFetched = false;
  let selectedGuest: Guest | null = null;
  let mapRendered = false;
  let currentView: 'overview' | 'detail' = 'overview';
  let activeTableId: string | null = null;

  // === Table positions — centered and spread across the 1000x700 viewBox ===
  const TABLE_POSITIONS: TablePosition[] = [
    // Row 1 (top)
    { x: 200, y: 150, radius: 42 },
    { x: 500, y: 130, radius: 42 },
    { x: 800, y: 150, radius: 42 },
    // Row 2 (middle-left and middle-right of dance floor)
    { x: 150, y: 350, radius: 42 },
    { x: 850, y: 350, radius: 42 },
    // Row 3 (bottom)
    { x: 200, y: 560, radius: 42 },
    { x: 500, y: 580, radius: 42 },
    { x: 800, y: 560, radius: 42 },
    // Extras (closer to dance floor)
    { x: 330, y: 250, radius: 38 },
    { x: 670, y: 250, radius: 38 },
    { x: 330, y: 470, radius: 38 },
    { x: 670, y: 470, radius: 38 },
    { x: 150, y: 560, radius: 36 },
    { x: 850, y: 560, radius: 36 },
  ];

  // === DOM refs ===
  const searchSection = document.getElementById('search-section')!;
  const searchForm = document.getElementById('search-form') as HTMLFormElement;
  const searchInput = document.getElementById('guest-search-input') as HTMLInputElement;
  const searchLoading = document.getElementById('search-loading')!;
  const searchResults = document.getElementById('search-results')!;
  const resultsList = document.getElementById('results-list') as HTMLUListElement;
  const noResults = document.getElementById('no-results')!;
  const searchError = document.getElementById('search-error')!;
  const retryBtn = document.getElementById('retry-btn')!;
  const mapSection = document.getElementById('map-section')!;
  const ementaSection = document.getElementById('ementa-section')!;
  const scrollToEmentaLink = document.getElementById('scroll-to-ementa')!;
  const searchAnnouncements = document.getElementById('search-announcements')!;
  const mapAnnouncements = document.getElementById('map-announcements')!;
  const floorPlanContainer = document.getElementById('floor-plan-container')!;
  const tablesGroup = document.getElementById('tables-group') as unknown as SVGGElement;
  const detailSheet = document.getElementById('detail-sheet')!;
  const detailTableName = document.getElementById('detail-table-name')!;
  const detailGuestList = document.getElementById('detail-guest-list')!;
  const backToOverviewBtn = document.getElementById('back-to-overview-btn')!;
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // === Helpers ===
  function hideAllMessages() {
    searchLoading.classList.add('hidden');
    searchResults.classList.add('hidden');
    noResults.classList.add('hidden');
    searchError.classList.add('hidden');
  }

  function announce(el: HTMLElement, msg: string) {
    el.textContent = msg;
  }

  // === API ===
  async function fetchGuests(): Promise<Guest[]> {
    if (guestsFetched) return allGuests;
    const res = await fetch('/api/guests');
    if (!res.ok) throw new Error('API error');
    allGuests = await res.json();
    guestsFetched = true;
    return allGuests;
  }

  async function fetchTables(): Promise<Table[]> {
    if (tablesFetched) return allTables;
    const res = await fetch('/api/tables');
    if (!res.ok) throw new Error('API error');
    allTables = await res.json();
    tablesFetched = true;
    return allTables;
  }

  // === SVG Rendering ===
  function svgEl(tag: string, attrs: Record<string, string>): SVGElement {
    const el = document.createElementNS('http://www.w3.org/2000/svg', tag);
    for (const [k, v] of Object.entries(attrs)) el.setAttribute(k, v);
    return el;
  }

  function renderTable(table: Table, pos: TablePosition, guests: Guest[]): SVGGElement {
    const { x, y, radius } = pos;
    const g = svgEl('g', {
      'data-table-id': table.id,
      'class': 'floor-table',
      'role': 'button',
      'tabindex': '0',
      'aria-label': `${table.name}, ${guests.length} de ${table.capacity} lugares`,
    }) as SVGGElement;

    // Table circle
    g.appendChild(svgEl('circle', {
      cx: String(x), cy: String(y), r: String(radius),
      fill: '#f5f0e3', stroke: '#c5c2a5', 'stroke-width': '1.5',
    }));

    // Inner ring
    g.appendChild(svgEl('circle', {
      cx: String(x), cy: String(y), r: String(radius - 10),
      fill: 'none', stroke: '#e8e4d4', 'stroke-width': '0.5', 'stroke-dasharray': '2 2',
    }));

    // Seats
    const seatDist = radius + 14;
    const total = table.capacity;
    for (let i = 0; i < total; i++) {
      const angle = (i / total) * Math.PI * 2 - Math.PI / 2;
      const sx = x + Math.cos(angle) * seatDist;
      const sy = y + Math.sin(angle) * seatDist;
      const occupied = i < guests.length;
      const isMe = occupied && selectedGuest && guests[i].id === selectedGuest.id;

      const attrs: Record<string, string> = {
        cx: String(sx), cy: String(sy), r: '7',
      };

      if (isMe) {
        attrs.fill = '#e6b040';
        attrs.stroke = '#d4983a';
        attrs['stroke-width'] = '1.5';
      } else if (occupied) {
        attrs.fill = '#c5c2a5';
        attrs.stroke = '#a9a57e';
        attrs['stroke-width'] = '1';
      } else {
        attrs.fill = '#fdfcf9';
        attrs.stroke = '#c5c2a5';
        attrs['stroke-width'] = '1';
        attrs['stroke-dasharray'] = '3 2';
      }

      g.appendChild(svgEl('circle', attrs));
    }

    // Table name
    const txt = svgEl('text', {
      x: String(x), y: String(y + 1),
      'text-anchor': 'middle', 'dominant-baseline': 'middle',
      'font-family': 'Montserrat, sans-serif', 'font-size': '9',
      'font-weight': '600', fill: '#74704a', 'pointer-events': 'none',
    });
    txt.textContent = table.name;
    g.appendChild(txt);

    return g;
  }

  function renderFloorPlan(tables: Table[]) {
    tablesGroup.innerHTML = '';
    if (tables.length === 0) {
      const t = svgEl('text', { x: '500', y: '350', 'text-anchor': 'middle', 'font-family': 'Montserrat, sans-serif', 'font-size': '14', fill: '#8f8a5e' });
      t.textContent = 'O mapa de mesas será disponibilizado em breve.';
      tablesGroup.appendChild(t);
      return;
    }

    const byTable = new Map<string, Guest[]>();
    tables.forEach(t => byTable.set(t.id, []));
    allGuests.forEach(g => { if (g.mesa_id && byTable.has(g.mesa_id)) byTable.get(g.mesa_id)!.push(g); });

    tables.forEach((table, i) => {
      const pos = TABLE_POSITIONS[i % TABLE_POSITIONS.length];
      tablesGroup.appendChild(renderTable(table, pos, byTable.get(table.id) || []));
    });
  }

  // === Zoom ===
  function zoomToTable(tableId: string) {
    const idx = allTables.findIndex(t => t.id === tableId);
    if (idx === -1) return;
    const pos = TABLE_POSITIONS[idx % TABLE_POSITIONS.length];

    currentView = 'detail';
    activeTableId = tableId;

    const scale = 2.5;
    const vw = floorPlanContainer.clientWidth;
    const vh = floorPlanContainer.clientHeight;
    const svgScale = Math.min(vw / 1000, vh / 700);
    const tx = vw / 2 - pos.x * svgScale * scale;
    const ty = vh / 2 - pos.y * svgScale * scale;

    floorPlanContainer.style.transition = prefersReducedMotion ? 'none' : 'transform 0.8s cubic-bezier(0.4, 0, 0.2, 1)';
    floorPlanContainer.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
    floorPlanContainer.style.transformOrigin = '0 0';

    // Highlight active table
    tablesGroup.querySelectorAll('.floor-table').forEach(g => g.classList.remove('table-active'));
    tablesGroup.querySelector(`[data-table-id="${tableId}"]`)?.classList.add('table-active');
  }

  function zoomToOverview() {
    currentView = 'overview';
    activeTableId = null;
    floorPlanContainer.style.transition = prefersReducedMotion ? 'none' : 'transform 0.8s cubic-bezier(0.4, 0, 0.2, 1)';
    floorPlanContainer.style.transform = 'translate(0,0) scale(1)';
    tablesGroup.querySelectorAll('.floor-table').forEach(g => g.classList.remove('table-active'));
    hideSheet();
  }

  // === Bottom Sheet / Sidebar ===
  function showSheet(tableId: string) {
    const table = allTables.find(t => t.id === tableId);
    if (!table) return;
    const guests = allGuests.filter(g => g.mesa_id === tableId);

    detailTableName.textContent = table.name;
    detailGuestList.innerHTML = '';

    if (guests.length === 0) {
      detailGuestList.innerHTML = '<p class="sheet-empty">Sem convidados atribuídos</p>';
    } else {
      guests.forEach(guest => {
        const isMe = selectedGuest && guest.id === selectedGuest.id;
        const div = document.createElement('div');
        div.className = 'sheet-guest' + (isMe ? ' sheet-guest-me' : '');
        div.innerHTML = `
          <span class="guest-dot${isMe ? ' dot-gold' : ''}"></span>
          <span class="guest-name">${guest.nome}</span>
          ${isMe ? '<span class="guest-you">(you)</span>' : ''}
        `;
        detailGuestList.appendChild(div);
      });
    }

    announce(mapAnnouncements, `${table.name}. ${guests.length} convidados.`);

    detailSheet.classList.remove('hidden');
    detailSheet.setAttribute('aria-hidden', 'false');
    requestAnimationFrame(() => {
      detailSheet.classList.add('visible');
    });
  }

  function hideSheet() {
    detailSheet.classList.remove('visible');
    detailSheet.setAttribute('aria-hidden', 'true');
    setTimeout(() => detailSheet.classList.add('hidden'), 350);
  }

  // === Show map ===
  async function showMap() {
    if (mapRendered) return;
    try {
      const [tables] = await Promise.all([fetchTables(), fetchGuests()]);
      renderFloorPlan(tables);
      mapRendered = true;
    } catch {
      const t = svgEl('text', { x: '500', y: '350', 'text-anchor': 'middle', 'font-family': 'Montserrat, sans-serif', 'font-size': '14', fill: '#c0392b' });
      t.textContent = 'Não foi possível carregar o mapa.';
      tablesGroup.appendChild(t);
    }
  }

  // === Guest selection ===
  function selectGuest(guest: Guest) {
    selectedGuest = guest;
    hideAllMessages();
    announce(searchAnnouncements, `${guest.nome} selecionado.`);

    // Show map and ementa (don't hide search — keep page scrollable)
    mapSection.classList.remove('hidden');
    ementaSection.classList.remove('hidden');

    // Scroll to map section
    mapSection.scrollIntoView({ behavior: 'smooth', block: 'start' });

    showMap().then(() => {
      if (mapRendered) renderFloorPlan(allTables);

      if (!guest.mesa_id) {
        showNoTable();
        return;
      }

      const delay = prefersReducedMotion ? 0 : 1500;
      setTimeout(() => {
        zoomToTable(guest.mesa_id!);
        const sheetDelay = prefersReducedMotion ? 0 : 850;
        setTimeout(() => showSheet(guest.mesa_id!), sheetDelay);
      }, delay);
    });
  }

  function showNoTable() {
    detailTableName.textContent = '';
    detailGuestList.innerHTML = `
      <div class="sheet-no-table">
        <div class="sheet-no-table-icon">✦</div>
        <p>A sua mesa ainda não foi atribuída.</p>
        <p class="sheet-no-table-hint">Volte mais tarde para descobrir onde se vai sentar.</p>
      </div>
    `;
    detailSheet.classList.remove('hidden');
    detailSheet.setAttribute('aria-hidden', 'false');
    requestAnimationFrame(() => detailSheet.classList.add('visible'));
  }

  // === Search ===
  async function handleSearch(query: string) {
    if (!query.trim()) { hideAllMessages(); return; }
    hideAllMessages();
    searchLoading.classList.remove('hidden');

    try {
      const guests = await fetchGuests();
      const q = query.trim().toLowerCase();
      const matches = guests.filter(g => g.nome.toLowerCase().includes(q));

      if (matches.length === 0) {
        hideAllMessages();
        noResults.classList.remove('hidden');
        announce(searchAnnouncements, 'Nenhum resultado encontrado.');
      } else if (matches.length === 1) {
        selectGuest(matches[0]);
      } else {
        hideAllMessages();
        searchResults.classList.remove('hidden');
        resultsList.innerHTML = '';
        announce(searchAnnouncements, `${matches.length} resultados encontrados.`);
        matches.forEach(guest => {
          const li = document.createElement('li');
          li.role = 'option';
          li.tabIndex = 0;
          li.className = 'result-item';
          li.innerHTML = `<span>${guest.nome}</span>${guest.mesa_id ? '<span class="result-dot">●</span>' : ''}`;
          li.addEventListener('click', () => selectGuest(guest));
          li.addEventListener('keydown', (e: KeyboardEvent) => {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectGuest(guest); }
          });
          resultsList.appendChild(li);
        });
      }
    } catch {
      hideAllMessages();
      searchError.classList.remove('hidden');
      announce(searchAnnouncements, 'Erro ao carregar dados.');
    }
  }

  // === Table click ===
  function navigateToTable(tableId: string) {
    if (currentView === 'detail') {
      hideSheet();
      setTimeout(() => {
        zoomToOverview();
        setTimeout(() => {
          zoomToTable(tableId);
          const d = prefersReducedMotion ? 0 : 850;
          setTimeout(() => showSheet(tableId), d);
        }, prefersReducedMotion ? 0 : 500);
      }, 350);
    } else {
      zoomToTable(tableId);
      const d = prefersReducedMotion ? 0 : 850;
      setTimeout(() => showSheet(tableId), d);
    }
  }

  // === Event listeners ===
  searchForm.addEventListener('submit', (e) => { e.preventDefault(); handleSearch(searchInput.value); });
  searchInput.addEventListener('keydown', (e) => { if (e.key === 'Escape') { hideAllMessages(); searchInput.value = ''; } });
  retryBtn.addEventListener('click', () => { guestsFetched = false; allGuests = []; handleSearch(searchInput.value); });

  backToOverviewBtn.addEventListener('click', () => {
    zoomToOverview();
    announce(mapAnnouncements, 'Vista geral das mesas');
  });

  tablesGroup.addEventListener('click', (e) => {
    const target = (e.target as Element).closest('.floor-table');
    if (!target) return;
    const id = target.getAttribute('data-table-id');
    if (id) navigateToTable(id);
  });

  tablesGroup.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key !== 'Enter' && e.key !== ' ') return;
    const target = (e.target as Element).closest('.floor-table');
    if (!target) return;
    const id = target.getAttribute('data-table-id');
    if (id) { e.preventDefault(); navigateToTable(id); }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && currentView === 'detail') { e.preventDefault(); zoomToOverview(); }
  });

  scrollToEmentaLink.addEventListener('click', (e) => {
    e.preventDefault();
    ementaSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>

