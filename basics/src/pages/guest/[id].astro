---
export function getStaticPaths() {
  return [];
}

const { params } = Astro;
const id = params.id;
---
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Informação do Convidado</title>
  </head>
  <body class="p-8">
    <h1 class="text-2xl font-bold mb-4">Detalhes</h1>
    <div id="content">A carregar...</div>

    <script>
      import { supabase } from '../../scripts/supabase';

      const pathParts = window.location.pathname.split('/');
      const guestId = pathParts[pathParts.length - 1] || pathParts[pathParts.length - 2];

      (async () => {
        try {
          const { data, error } = await supabase
            .from('guests')
            .select('*')
            .eq('id', guestId)
            .single();

          if (error || !data) throw new Error('not found');

          document.getElementById('content')!.innerHTML = `
            <p><strong>Nome:</strong> ${data.nome}</p>
            <p><strong>Email:</strong> ${data.email || 'N/A'}</p>
            <p><strong>Mesa:</strong> ${data.mesa_id || 'Ainda sem atribuição'}</p>
            <p><strong>Restrições:</strong> ${data.restricoes || 'Nenhuma'}</p>
          `;
        } catch (err) {
          document.getElementById('content')!.innerText = 'Convidado não encontrado.';
        }
      })();
    </script>
  </body>
</html>
